    <!-- Outputs Panel -->
    <div class="panel panel-output" style="position: relative;">
      <!-- Simulation Processing Overlay -->
      <div id="line-sim-overlay" class="sim-overlay">
        <div class="sim-spinner"></div>
        <div class="sim-title">Evaluating Pipeline Hydraulics</div>
        <div class="sim-scanline"></div>
        <div class="sim-console-text">Solving fluid velocities and Reynolds...</div>
      </div>
      <div class="panel-header">
        <span class="panel-title">TECHNICAL EVALUATIONS DATASHEET — LINE SIZING</span>
      </div>
      <div class="panel-body">
        <div id="line-results" class="results-container">
          <!-- Sizing Status Banner -->
          <div class="status-banner banner-teal" style="margin-bottom: var(--space-md); padding: 8px 12px; border: 1px solid var(--border-muted); border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 10px; display: flex; justify-content: space-between; align-items: center;">
            <span class="banner-message">READY // BHARAT FLOWSIZE ACTIVE</span>
          </div>
          <div class="results-layout-wrapper">
            <!-- Left Column: Visualizations & Audits -->
            <div class="results-column-visual">
              <div class="iso-animation-wrapper" style="margin-top: 0;">
                <div class="chart-title" style="display: flex; justify-content: space-between; align-items: center;">
                  <span>3D PHYSICAL FLOW SIMULATION — PIPELINE SECTION</span>
                  <button type="button" id="btn-anim-pause-line" class="sthe-collapse-btn" style="padding: 1px 6px; font-size: 9px; line-height: 1;">PAUSE</button>
                </div>
                <div id="line-3d-container" class="iso-animation-container" style="position: relative;">
                  <canvas id="line-canvas" width="520" height="260" style="width:100%;max-width:520px;height:260px;display:block;background:#050810;border-radius:8px;"></canvas>
                </div>
              </div>
              <div class="rec-panel" style="margin-top: var(--space-md);">
                <div class="rec-title">COMPLIANCE AUDIT AUDIT VERDICTS</div>
                <div class="rec-list">
                  <div class="rec-item" data-unit-type="velocity" id="crit-velocity">✓ Fluid velocity is within recommended range</div>
                  <div class="rec-item" data-unit-type="press-drop" id="crit-dp">✓ Pressure drop is within design limit</div>
                </div>
              </div>
            </div>
            <!-- Right Column: Numeric Results -->
            <div class="results-column-data" style="max-height: calc(100vh - 220px); overflow-y: auto; overflow-x: hidden;">
              <div style="margin-bottom: var(--space-md);">
                <div class="rec-title" style="color: var(--color-saffron); margin-bottom: 6px; font-weight: bold; font-size: 11px;">PRIMARY RESULTS</div>
                <div class="table-responsive" style="border: 1px solid var(--border-muted); border-radius: var(--radius-sm); overflow: hidden; background: var(--bg-input);">
                  <table class="report-table" style="width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 10px; color: var(--text-main);">
                    <thead>
                      <tr style="border-bottom: 2px solid var(--border-muted); background: rgba(255,255,255,0.02); text-align: left;">
