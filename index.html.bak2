                        <th style="padding: 4px 6px; font-weight: 600; color: var(--text-header); width: 80px;">Unit</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">P&ID No</td>
                        <td id="out-line-pid" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Line From → To</td>
                        <td id="out-line-route" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">NPS</td>
                        <td id="out-line-nps" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
