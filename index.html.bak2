                            <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);"><input type="radio" name="gas-active-service" value="vacuum" style="cursor: pointer; accent-color: var(--color-saffron);"></td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); color: var(--text-header);">Vacuum Gas Lines</td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); text-align: center; white-space: nowrap;"><input type="number" class="form-control table-input" value="10" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;"> to <input type="number" class="form-control table-input" value="15" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;"></td>
                            <td style="padding: 4px; text-align: right;"><input type="number" class="form-control table-input" value="0.05" step="any" style="width: 60px; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;"></td>
                          </tr>
                          <tr>
                            <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);"><input type="radio" name="gas-active-service" value="user" style="cursor: pointer; accent-color: var(--color-saffron);"></td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); color: var(--text-header);">User Defined</td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); text-align: center; white-space: nowrap;"><input type="number" class="form-control table-input" placeholder="0.0" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;"> to <input type="number" class="form-control table-input" placeholder="0.0" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;"></td>
                            <td style="padding: 4px; text-align: right;"><input type="number" class="form-control table-input" placeholder="0.0" step="any" style="width: 60px; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;"></td>
                          </tr>
                        </tbody>
                      </table>
                    </div>
                    <div style="margin-top: 6px; font-family: var(--font-mono); font-size: 9px; color: var(--text-muted); text-align: right;">
                      <span id="lbl-active-gas-service" class="banner-badge" style="border-color: var(--color-saffron); color: var(--color-saffron); font-size: 9px; padding: 2px 6px;">Active: Gas/Vapor Line (General) | V: 10.0–25.0 m/s | ΔP: 0.20 bar/100m</span>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>API 14E Erosional Velocity Limits</legend>
                    <div class="input-grid-2">
                      <div class="input-cell">
                        <label>Gas Service C Factor</label>
                        <table class="data-table" style="width: 100%; font-size: 9px; margin-bottom: 0;">
                          <thead><tr><th style="width: 20px;">✓</th><th>Service</th><th style="text-align: right;">C Value</th></tr></thead>
                          <tbody>
                            <tr><td style="text-align: center;"><input type="radio" name="gas-erosion-c" value="175"></td><td>Clean Gas</td><td style="text-align: right;"><input type="number" class="form-control table-input" value="175" style="width:40px; text-align:right;"></td></tr>
                            <tr><td style="text-align: center;"><input type="radio" name="gas-erosion-c" value="200"></td><td>Dry Natural Gas</td><td style="text-align: right;"><input type="number" class="form-control table-input" value="200" style="width:40px; text-align:right;"></td></tr>
                            <tr><td style="text-align: center;"><input type="radio" name="gas-erosion-c" value="175" checked></td><td>Non-corrosive Gas</td><td style="text-align: right;"><input type="number" class="form-control table-input" value="175" style="width:40px; text-align:right;"></td></tr>
                            <tr><td style="text-align: center;"><input type="radio" name="gas-erosion-c" value="112"></td><td>Corrosive Gas</td><td style="text-align: right;"><input type="number" class="form-control table-input" value="112" style="width:40px; text-align:right;"></td></tr>
                            <tr><td style="text-align: center;"><input type="radio" name="gas-erosion-c" value="75"></td><td>Gas with Solids</td><td style="text-align: right;"><input type="number" class="form-control table-input" value="75" style="width:40px; text-align:right;"></td></tr>
                            <tr><td style="text-align: center;"><input type="radio" name="gas-erosion-c" value="100"></td><td>Offshore Production</td><td style="text-align: right;"><input type="number" class="form-control table-input" value="100" style="width:40px; text-align:right;"></td></tr>
                            <tr><td style="text-align: center;"><input type="radio" name="gas-erosion-c" value="user"></td><td>User Defined</td><td style="text-align: right;"><input type="number" class="form-control table-input" placeholder="0" style="width:40px; text-align:right;"></td></tr>
                          </tbody>
                        </table>
                      </div>
                      <div class="input-cell">
                        <label for="gas-erosion-setpoint">Design Set Point (%)</label>
                        <div class="input-with-unit">
                          <input type="number" id="gas-erosion-setpoint" class="form-control text-data" value="30" step="any" required>
                          <span class="unit">%</span>
                        </div>
                      </div>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Pipeline Route &amp; Elevation</legend>
                    <div class="input-grid-3">
                      <div class="input-cell">
                        <label for="gas-length">Pipe Length (L)</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="length-m" id="gas-length" class="form-control text-data" value="10" step="any" required>
                          <span class="unit" data-unit-type="length-m">m</span>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="gas-elevation">Elevation Change (h)</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="length-m" id="gas-elevation" class="form-control text-data" value="20" step="any" required>
                          <span class="unit" data-unit-type="length-m">m</span>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="gas-other-dp">Other Acc Drop</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="press-drop" id="gas-other-dp" class="form-control text-data" value="0.001" step="any" required>
                          <span class="unit" data-unit-type="press-drop">bar</span>
                        </div>
                      </div>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Fittings &amp; Valves — K Value Method</legend>
                    <div style="overflow-x: auto; max-height: 250px; overflow-y: auto;">
                      <table id="gas-fittings-table" class="data-table" style="width: 100%; font-size: 9px; margin-bottom: 0;">
                        <thead style="position: sticky; top: 0; background: var(--bg-panel); z-index: 1;">
                          <tr>
                            <th style="text-align: left;">Fitting Name</th>
                            <th style="text-align: right; width: 60px;">K Factor</th>
                            <th style="text-align: center; width: 50px;">Qty</th>
                          </tr>
                        </thead>
                        <tbody>
                          <tr><td>Gate Valve</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.14" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Globe Valve</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="6.10" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Angle Valve</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.99" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Ball Valve</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.05" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Plug Valve Straightway</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.32" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Plug Valve 3-Way Through</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.54" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Plug Valve Branch Flow</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="1.62" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Swing Check Valve</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.90" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Lift Check Valve</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="10.80" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Standard Elbow 90°</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.54" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Standard Elbow 45°</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.29" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Long Radius Elbow 90°</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.29" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Tee Through Flow</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.36" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Tee Through Branch</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="1.08" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Mitre Bend α=0° Straight</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.04" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Mitre Bend α=30° Mild</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.14" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Mitre Bend α=60° Moderate</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="0.45" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                          <tr><td>Mitre Bend α=90° Sharp</td><td style="text-align: right;"><input type="number" class="k-val form-control table-input" value="1.08" style="width:50px; text-align:right;"></td><td style="text-align: center;"><input type="number" class="k-qty form-control table-input" value="1" style="width:40px; text-align:center;"></td></tr>
                        </tbody>
                      </table>
                    </div>
                    <div style="margin-top: 6px; font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); text-align: right;">
                      <span id="lbl-gas-minor-sum-k" style="color: var(--text-header); font-weight: bold;">ΣK=XX.XX</span>
                    </div>
                  </fieldset>
                </form>
              </div>
            </div>

            <!-- Right Column: Results -->
            <div class="panel panel-results">
              <div class="panel-header" style="justify-content: space-between;">
                <span class="panel-title">DATASHEET — GAS HYDRAULIC PROFILE</span>
                <button class="btn btn-primary btn-sm" onclick="window.print()">EXPORT PDF</button>
              </div>
              <div class="panel-body" style="padding: 0; max-height: calc(100vh - 180px); overflow-y: auto; overflow-x: hidden;">
                
                <!-- Banners -->
                <div id="gas-banner-velocity" class="banner-badge" style="display: none; background: rgba(239, 68, 68, 0.1); color: var(--color-danger); border-color: var(--color-danger); margin: var(--space-sm) var(--space-md); text-align: center; font-size: 10px;">⚠ High Velocity — Velocity exceeds recommended limit. Consider larger pipe size.</div>
                <div id="gas-banner-dp" class="banner-badge" style="display: none; background: rgba(239, 68, 68, 0.1); color: var(--color-danger); border-color: var(--color-danger); margin: var(--space-sm) var(--space-md); text-align: center; font-size: 10px;">⚠ High Pressure Drop — Pressure drop exceeds allowable limit. Increase pipe diameter.</div>
                <div id="gas-banner-mach" class="banner-badge" style="display: none; background: rgba(245, 158, 11, 0.1); color: var(--color-warn); border-color: var(--color-warn); margin: var(--space-sm) var(--space-md); text-align: center; font-size: 10px;">⚠ High Mach Number — Mach ≥ 0.3. Compressibility effects may be significant.</div>
                <div id="gas-banner-choke" class="banner-badge" style="display: none; background: rgba(239, 68, 68, 0.1); color: var(--color-danger); border-color: var(--color-danger); margin: var(--space-sm) var(--space-md); text-align: center; font-size: 10px;">⚠ SONIC / CHOKED FLOW — Mach ≥ 1.0. Design NOT acceptable.</div>
                <div id="gas-banner-noise" class="banner-badge" style="display: none; background: rgba(245, 158, 11, 0.1); color: var(--color-warn); border-color: var(--color-warn); margin: var(--space-sm) var(--space-md); text-align: center; font-size: 10px;">⚠ Noise Warning — High gas velocity may cause vibration and noise.</div>

                <div style="padding: 0 var(--space-md) var(--space-md) var(--space-md);">
                  <div class="result-section">
                    <div class="result-title">PRIMARY RESULTS</div>
                    <table style="width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 10px; color: var(--text-main);">
                      <thead>
                        <tr style="border-bottom: 1px solid var(--border-muted); background: rgba(255,255,255,0.02);">
                          <th style="padding: 4px 6px; text-align: left; width: 50%;">Parameter</th>
                          <th style="padding: 4px 6px; text-align: right; width: 30%;">Value</th>
                          <th style="padding: 4px 6px; text-align: left; width: 20%;">Unit</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">P&amp;ID No</td>
                          <td id="out-gas-pid" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Line From → To</td>
                          <td id="out-gas-route" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">NPS</td>
                          <td id="out-gas-nps" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">inches</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Pipe Schedule</td>
                          <td id="out-gas-schedule" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Nominal Line Diameter</td>
                          <td id="out-gas-nom-dia" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">inches</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Pipe OD</td>
                          <td id="out-gas-od" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">inches/mm</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Nominal ID</td>
                          <td id="out-gas-nominal-id" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">mm</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Fluid</td>
                          <td id="out-gas-fluid" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Operating Temperature (Normal)</td>
                          <td id="out-gas-operating-temp" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td class="unit" data-unit-type="temperature" style="padding: 4px 6px; color: var(--text-muted);">°C</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Gas Service Condition</td>
                          <td id="out-gas-service" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Molecular Weight</td>
                          <td id="out-gas-mw" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">kg/kmol</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Dynamic Viscosity (μ)</td>
                          <td id="out-gas-viscosity" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td class="unit" data-unit-type="viscosity" style="padding: 4px 6px; color: var(--text-muted);">cP</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Compressibility Factor (Z)</td>
                          <td id="out-gas-z" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">γ (Cp/Cv)</td>
                          <td id="out-gas-gamma" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Gas Density (kg/m³)</td>
                          <td id="out-gas-density-kg" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td class="unit" data-unit-type="density" style="padding: 4px 6px; color: var(--text-muted);">kg/m³</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Gas Density (lb/ft³)</td>
                          <td id="out-gas-density-lb" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">lb/ft³</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Upstream Pressure</td>
                          <td id="out-gas-upstream-press" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td class="unit" data-unit-type="pressure" style="padding: 4px 6px; color: var(--text-muted);">bar G</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Downstream Pressure</td>
                          <td id="out-gas-downstream-press" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--color-teal);">-</td>
                          <td class="unit" data-unit-type="pressure" style="padding: 4px 6px; color: var(--text-muted);">bar G</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Total Pressure Drop</td>
                          <td id="out-gas-total-dp" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td class="unit" data-unit-type="press-drop" style="padding: 4px 6px; color: var(--text-muted);">bar</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">ΔP per 100m</td>
                          <td id="out-gas-dp-per-100m" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td class="unit" data-unit-type="press-drop-rate" style="padding: 4px 6px; color: var(--text-muted);">bar/100m</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Design Volumetric Flow</td>
                          <td id="out-gas-vol-flow" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td class="unit" data-unit-type="vol-flow" style="padding: 4px 6px; color: var(--text-muted);">m³/hr</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Mass Flowrate</td>
                          <td id="out-gas-mass-flow" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td class="unit" data-unit-type="mass-flow" style="padding: 4px 6px; color: var(--text-muted);">kg/hr</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Gas Line Velocity</td>
                          <td id="out-gas-velocity" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--color-teal);">-</td>
                          <td class="unit" data-unit-type="velocity" style="padding: 4px 6px; color: var(--text-muted);">m/s</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Speed of Sound</td>
                          <td id="out-gas-sonic-vel" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td class="unit" data-unit-type="velocity" style="padding: 4px 6px; color: var(--text-muted);">m/s</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Mach Number</td>
                          <td id="out-gas-mach" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Reynolds Number</td>
                          <td id="out-gas-reynolds" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Flow Behavior</td>
                          <td id="out-gas-behavior" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Friction Factor (f)</td>
                          <td id="out-gas-f-factor" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Relative Roughness (ε/D)</td>
                          <td id="out-gas-rel-roughness" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Erosion Velocity (API 14E 100%)</td>
                          <td id="out-gas-v-erosion-100" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td class="unit" data-unit-type="velocity" style="padding: 4px 6px; color: var(--text-muted);">m/s</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Design Erosion Velocity (Setpoint)</td>
                          <td id="out-gas-v-erosion-design" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td class="unit" data-unit-type="velocity" style="padding: 4px 6px; color: var(--text-muted);">m/s</td>
                        </tr>
                        <tr>
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Erosion Condition</td>
                          <td id="out-gas-erosion-cond" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                          <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>

                  <div class="result-section">
                    <div class="result-title">PRESSURE DROP BREAKDOWN</div>
                    <table style="width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 10px; color: var(--text-main);">
                      <thead>
                        <tr style="border-bottom: 1px solid var(--border-muted); background: rgba(255,255,255,0.02);">
                          <th style="padding: 4px 6px; text-align: left; width: 60%;">Component</th>
                          <th style="padding: 4px 6px; text-align: right; width: 20%;">Pa</th>
                          <th style="padding: 4px 6px; text-align: right; width: 20%;">bar</th>
                        </tr>
                      </thead>
                      <tbody>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Major Loss (Darcy-Weisbach)</td>
                          <td id="out-gas-dp-major-pa" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right;">-</td>
                          <td id="out-gas-dp-major-bar" style="padding: 4px 6px; text-align: right; color: var(--text-header);">-</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Static Head (Elevation)</td>
                          <td id="out-gas-dp-static-pa" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right;">-</td>
                          <td id="out-gas-dp-static-bar" style="padding: 4px 6px; text-align: right; color: var(--text-header);">-</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Minor Loss (K method) <span id="out-gas-minor-lbl"></span></td>
                          <td id="out-gas-dp-minor-pa" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right;">-</td>
                          <td id="out-gas-dp-minor-bar" style="padding: 4px 6px; text-align: right; color: var(--text-header);">-</td>
                        </tr>
                        <tr style="border-bottom: 1px solid var(--border-muted);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Other (Instruments/Vendor)</td>
                          <td id="out-gas-dp-other-pa" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right;">-</td>
                          <td id="out-gas-dp-other-bar" style="padding: 4px 6px; text-align: right; color: var(--text-header);">-</td>
                        </tr>
                        <tr style="background: rgba(0, 196, 160, 0.05);">
                          <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted); font-weight: bold; color: var(--color-teal);">TOTAL PRESSURE DROP</td>
                          <td id="out-gas-dp-total-pa" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; font-weight: bold; color: var(--color-teal);">-</td>
                          <td id="out-gas-dp-total-bar" style="padding: 4px 6px; text-align: right; font-weight: bold; color: var(--color-teal);">-</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>

                  <div class="result-section">
                    <div class="result-title">COMPLIANCE STATUS VERDICTS</div>
                    <div style="display: flex; flex-direction: column; gap: 8px;">
                      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border-muted); padding-bottom: 4px;">
                        <span>Velocity vs Min Range:</span>
                        <span id="badge-gas-vel-min" class="badge">-</span>
                      </div>
                      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border-muted); padding-bottom: 4px;">
                        <span>Velocity vs Max Range:</span>
                        <span id="badge-gas-vel-max" class="badge">-</span>
                      </div>
                      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border-muted); padding-bottom: 4px;">
                        <span>Pipe Size Recommendation:</span>
                        <span id="badge-gas-vel-rec" class="badge">-</span>
                      </div>
                      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border-muted); padding-bottom: 4px;">
                        <span>ΔP per 100m Condition:</span>
                        <span id="badge-gas-dp-status" class="badge">-</span>
                      </div>
                      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border-muted); padding-bottom: 4px;">
                        <span>Erosion Condition:</span>
                        <span id="badge-gas-erosion-status" class="badge">-</span>
                      </div>
                      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--border-muted); padding-bottom: 4px;">
                        <span>Mach Number Condition:</span>
                        <span id="badge-gas-mach-status" class="badge">-</span>
                      </div>
                      <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span>Flow Behavior:</span>
                        <span id="badge-gas-regime-status" class="badge">-</span>
                      </div>
                    </div>
                  </div>

                  <div id="gas-assistant-panel" class="rec-panel" style="display: none; border-left: 4px solid var(--color-saffron); background: rgba(255, 117, 56, 0.05); margin-top: var(--space-md); padding: 12px var(--space-md); font-family: var(--font-mono); border-top: 1px solid rgba(255, 117, 56, 0.15); border-right: 1px solid rgba(255, 117, 56, 0.15); border-bottom: 1px solid rgba(255, 117, 56, 0.15); border-radius: var(--radius-sm);">
                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                      <span style="font-size: 14px;">⚠</span>
                      <span style="font-weight: bold; font-size: 11px; color: var(--color-saffron);">GAS LINE SIZING DESIGN ASSISTANT — AUTO CORRECTION SUGGESTIONS</span>
                    </div>
                    <div id="gas-assistant-content" style="font-size: 10px; color: var(--text-main);">
                      <!-- Live recommendations will be injected here -->
                    </div>
                  </div>

                </div>
              </div>
            </div>
          </div>
        </div>

        <div id="line-steam-content" class="line-type-content">
      <div class="sizing-grid">
        <!-- Left Column: Inputs -->
        <div class="panel panel-input" style="max-height: calc(100vh - 180px); overflow-y: auto; overflow-x: hidden;">
          <div class="panel-header">
            <span class="panel-title">DESIGN DATA METRICS — STEAM PIPELINE SIZING</span>
          </div>
          <div class="panel-body">
            <div class="digital-badge">Atmanirbhar Bharat Digitalization</div>
            <form id="steam-form">
              <fieldset class="form-group">
                <legend>Fluid Properties Configuration</legend>
                <div class="input-row">
                  <div class="input-cell">
                    <label for="steam-pressure">Operating Pressure</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="pressure" id="steam-pressure" class="form-control text-data" value="10.0" step="any" required>
                      <span class="unit" data-unit-type="pressure">bar A</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="steam-temp">Operating Temperature</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="temperature" id="steam-temp" class="form-control text-data" value="180" step="any" required>
                      <span class="unit" data-unit-type="temperature">°C</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="steam-mass-flow">Mass Flow Rate</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="mass-flow" id="steam-mass-flow" class="form-control text-data" value="5000" step="any" required>
                      <span class="unit" data-unit-type="mass-flow">kg/hr</span>
                    </div>
                  </div>
                </div>
              </fieldset>
              <fieldset class="form-group" style="margin-top: var(--space-md);">
                <legend>Pipeline Routing & Geometry</legend>
                <div class="input-grid-3">
                  <div class="input-cell">
                    <label for="steam-material">Pipe Material</label>
                    <div class="select-wrapper">
                      <select id="steam-material" class="form-control">
                        <option value="cs" selected>CS (Carbon Steel)</option>
                        <option value="ss">SS (Stainless Steel)</option>
                        <option value="pvc">PVC (Plastic)</option>
                        <option value="ci">Cast Iron</option>
                        <option value="concrete">Concrete</option>
                      </select>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="steam-roughness">Roughness (ε)</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="length-mm" id="steam-roughness" class="form-control text-data" value="0.045" step="any" required>
                      <span class="unit" data-unit-type="length-mm">mm</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="steam-nps">Nominal Size (NPS)</label>
                    <div class="select-wrapper">
                      <select id="steam-nps" class="form-control">
                        <option value="0.5">½"</option>
                        <option value="0.75">¾"</option>
                        <option value="1">1"</option>
                        <option value="1.5">1½"</option>
                        <option value="2">2"</option>
                        <option value="3">3"</option>
                        <option value="4" selected>4"</option>
                        <option value="6">6"</option>
                        <option value="8">8"</option>
                        <option value="10">10"</option>
                        <option value="12">12"</option>
                        <option value="14">14"</option>
                        <option value="16">16"</option>
                        <option value="18">18"</option>
                        <option value="20">20"</option>
                        <option value="24">24"</option>
                      </select>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="steam-schedule">Pipe Schedule</label>
                    <div class="select-wrapper">
                      <select id="steam-schedule" class="form-control">
                        <option value="STD">STD</option>
                        <option value="40" selected>40</option>
                        <option value="80">80</option>
                        <option value="160">160</option>
                      </select>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="steam-id">Auto-filled ID</label>
                    <div class="input-with-unit">
                      <input type="number" id="steam-id" class="form-control text-data" value="4.026" step="any" required>
                      <span class="unit">inches</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="steam-length">Pipe Route Length</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="length-m" id="steam-length" class="form-control text-data" value="100" step="any" required>
                      <span class="unit" data-unit-type="length-m">m</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="steam-elevation">Elevation Change (ΔZ)</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="length-m" id="steam-elevation" class="form-control text-data" value="0" step="any">
                      <span class="unit" data-unit-type="length-m">m</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="steam-other-dp">Other Losses (ΔP_other)</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="press-drop" id="steam-other-dp" class="form-control text-data" value="0" step="any">
                      <span class="unit" data-unit-type="press-drop">bar</span>
                    </div>
                  </div>
                </div>
              </fieldset>
              <button type="submit" class="btn btn-primary btn-block" style="margin-top: var(--space-md);">
                <span class="btn-text">RUN STEAM HYDRAULICS</span>
                <span class="btn-icon">⚡</span>
              </button>
            </form>
      </div>
    </div>

    <!-- Outputs Panel -->
    <div class="panel panel-output" style="position: relative;">
      <!-- Simulation Processing Overlay -->
      <div id="steam-sim-overlay" class="sim-overlay">
        <div class="sim-spinner"></div>
        <div class="sim-title">Evaluating Steam Sizing</div>
        <div class="sim-scanline"></div>
        <div class="sim-console-text">Solving steam thermodynamic states...</div>
      </div>
      <div class="panel-header">
        <span class="panel-title">TECHNICAL EVALUATIONS DATASHEET — STEAM LINE SIZING</span>
      </div>
      <div class="panel-body">
        <div id="steam-results" class="results-container">
          <div class="results-layout-wrapper">
            <!-- Left Column: Visualizations & Warnings -->
            <div class="results-column-visual">
              <div class="iso-animation-wrapper" style="margin-top: 0;">
                <div class="chart-title" style="display: flex; justify-content: space-between; align-items: center;">
                  <span>3D PHYSICAL FLOW SIMULATION — STEAM SECTION</span>
                  <button type="button" id="btn-anim-pause-steam" class="sthe-collapse-btn" style="padding: 1px 6px; font-size: 9px; line-height: 1;">PAUSE</button>
                </div>
                <div id="steam-3d-container" class="iso-animation-container" style="position: relative;">
                  <canvas id="steam-animation-canvas" style="width: 100%; height: 100%; position: absolute; left:0; top:0;"></canvas>
                </div>
              </div>
              <div class="rec-panel" style="margin-top: var(--space-md);">
                <div class="rec-title">STEAM PROPERTIES</div>
                <div class="rec-list">
                  <div class="rec-item">Sat Temp: <span data-unit-type="temperature" id="out-steam-tsat" class="text-teal">-</span> <span class="card-unit" data-unit-type="temperature">°C</span></div>
                  <div class="rec-item">Spec Vol: <span id="out-steam-sv" class="text-teal">-</span> <span class="card-unit">m³/kg</span></div>
                </div>
              </div>
            </div>
            <!-- Right Column: Numeric Results -->
            <div class="results-column-data">
              <div class="results-grid">
                <div class="result-card">
                  <div class="card-label">Pipe Inside ID</div>
                  <div class="card-value"><span data-unit-type="length-mm" id="out-steam-id-mm">0.0</span><span class="card-unit" data-unit-type="length-mm">mm</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Steam Density</div>
                  <div class="card-value"><span data-unit-type="density" id="out-steam-density">0.000</span><span class="card-unit" data-unit-type="density">kg/m³</span></div>
                </div>
                <div class="result-card highlight">
                  <div class="card-label">Line Velocity</div>
                  <div class="card-value text-teal"><span data-unit-type="velocity" id="out-steam-velocity">0.00</span><span class="card-unit" data-unit-type="velocity">m/s</span></div>
                </div>
              </div>
              <div class="results-grid" style="margin-top: var(--space-md);">
                <div class="result-card">
                  <div class="card-label">Volumetric Flow</div>
                  <div class="card-value"><span id="out-steam-vol-flow">0.00</span><span class="card-unit" data-unit-type="vol-flow">m³/hr</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Friction Loss (Pipe)</div>
                  <div class="card-value"><span data-unit-type="press-drop" id="out-steam-dp-pipe">0.0000</span><span class="card-unit" data-unit-type="press-drop">bar</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Fittings & Valves Loss</div>
                  <div class="card-value"><span data-unit-type="press-drop" id="out-steam-dp-fittings">0.0000</span><span class="card-unit" data-unit-type="press-drop">bar</span></div>
                </div>
              </div>
              <div class="results-grid" style="margin-top: var(--space-md);">
                <div class="result-card">
                  <div class="card-label">Elevation Change Loss</div>
                  <div class="card-value"><span data-unit-type="press-drop" id="out-steam-dp-elevation">0.0000</span><span class="card-unit" data-unit-type="press-drop">bar</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Other Losses (ΔP_other)</div>
                  <div class="card-value"><span data-unit-type="press-drop" id="out-steam-dp-other">0.0000</span><span class="card-unit" data-unit-type="press-drop">bar</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Erosion Limit (API 14E)</div>
                  <div class="card-value"><span id="out-steam-v-erosion">0.00</span><span class="card-unit" data-unit-type="velocity">m/s</span></div>
                </div>
              </div>
              <div class="results-grid" style="margin-top: var(--space-md);">
                <div class="result-card highlight">
                  <div class="card-label font-bold">TOTAL PRESSURE DROP</div>
                  <div class="card-value text-teal"><span data-unit-type="press-drop" id="out-steam-dp-total">0.0000</span><span class="card-unit" data-unit-type="press-drop">bar</span></div>
                </div>
                <div class="result-card highlight">
                  <div class="card-label">Unit Loss Drop Rate</div>
                  <div class="card-value text-teal"><span data-unit-type="press-drop" id="out-steam-dp-100m">0.000</span><span class="card-unit" data-unit-type="press-drop">bar/100m</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

    

    <!-- LINE SUB-TAB 4: SLURRY SIZING -->
    <div id="line-slurry-content" class="line-type-content">
      <div class="sizing-grid">
                <div class="panel panel-input" style="max-height: calc(100vh - 180px); overflow-y: auto; overflow-x: hidden;">
          <div class="panel-header">
            <span class="panel-title">DESIGN DATA METRICS — SLURRY PIPELINE SIZING</span>
          </div>
          <div class="panel-body">
            <div class="digital-badge">Atmanirbhar Bharat Digitalization</div>
            <form id="slurry-form">
              <fieldset class="form-group">
                <legend>Slurry Properties Configuration</legend>
                <div class="input-row">
                  <div class="input-cell">
                    <label for="slurry-carrier-density">Carrier Fluid Density</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="density" id="slurry-carrier-density" class="form-control text-data" value="1000" step="any" required>
                      <span class="unit" data-unit-type="density">kg/m³</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="slurry-carrier-viscosity">Carrier Fluid Viscosity</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="viscosity" id="slurry-carrier-viscosity" class="form-control text-data" value="1.0" step="any" required>
                      <span class="unit" data-unit-type="viscosity">cP</span>
                    </div>
                  </div>
                </div>
                <div class="input-row" style="margin-top: var(--space-sm);">
                  <div class="input-cell">
                    <label for="slurry-solid-density">Solids Density</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="density" id="slurry-solid-density" class="form-control text-data" value="2650" step="any" required>
                      <span class="unit" data-unit-type="density">kg/m³</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="slurry-d50">Solids d50 Particle Size</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="length-mm" id="slurry-d50" class="form-control text-data" value="0.2" step="any" required>
                      <span class="unit" data-unit-type="length-mm">mm</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="slurry-wt-percent">Solids Concentration (Wt %)</label>
                    <div class="input-with-unit">
                      <input type="number" id="slurry-wt-percent" class="form-control text-data" value="30" step="any" required>
                      <span class="unit">%</span>
                    </div>
                  </div>
                </div>
                <div class="input-row" style="margin-top: var(--space-sm);">
                  <div class="input-cell">
                    <label for="slurry-mass-flow">Total Slurry Mass Flow</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="mass-flow" id="slurry-mass-flow" class="form-control text-data" value="50000" step="any" required>
                      <span class="unit" data-unit-type="mass-flow">kg/hr</span>
                    </div>
                  </div>
                </div>
              </fieldset>
              <fieldset class="form-group" style="margin-top: var(--space-md);">
                <legend>Pipeline Routing & Geometry</legend>
                <div class="input-grid-3">
                  <div class="input-cell">
                    <label for="slurry-material">Pipe Material</label>
                    <div class="select-wrapper">
                      <select id="slurry-material" class="form-control">
                        <option value="cs" selected>CS (Carbon Steel)</option>
                        <option value="ss">SS (Stainless Steel)</option>
                        <option value="pvc">PVC (Plastic)</option>
                        <option value="ci">Cast Iron</option>
                        <option value="concrete">Concrete</option>
                      </select>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="slurry-roughness">Roughness (ε)</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="length-mm" id="slurry-roughness" class="form-control text-data" value="0.045" step="any" required>
                      <span class="unit" data-unit-type="length-mm">mm</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="slurry-nps">Nominal Size (NPS)</label>
                    <div class="select-wrapper">
                      <select id="slurry-nps" class="form-control">
                        <option value="0.5">½"</option>
                        <option value="0.75">¾"</option>
                        <option value="1">1"</option>
                        <option value="1.5">1½"</option>
                        <option value="2">2"</option>
                        <option value="3">3"</option>
                        <option value="4" selected>4"</option>
                        <option value="6">6"</option>
                        <option value="8">8"</option>
                        <option value="10">10"</option>
                        <option value="12">12"</option>
                        <option value="14">14"</option>
                        <option value="16">16"</option>
                        <option value="18">18"</option>
                        <option value="20">20"</option>
                        <option value="24">24"</option>
                      </select>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="slurry-schedule">Pipe Schedule</label>
                    <div class="select-wrapper">
                      <select id="slurry-schedule" class="form-control">
                        <option value="STD">STD</option>
                        <option value="40" selected>40</option>
                        <option value="80">80</option>
                        <option value="160">160</option>
                      </select>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="slurry-id">Auto-filled ID</label>
                    <div class="input-with-unit">
                      <input type="number" id="slurry-id" class="form-control text-data" value="4.026" step="any" required>
                      <span class="unit">inches</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="slurry-length">Pipe Route Length</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="length-m" id="slurry-length" class="form-control text-data" value="100" step="any" required>
                      <span class="unit" data-unit-type="length-m">m</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="slurry-elevation">Elevation Change (ΔZ)</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="length-m" id="slurry-elevation" class="form-control text-data" value="0" step="any">
                      <span class="unit" data-unit-type="length-m">m</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="slurry-other-dp">Other Losses (ΔP_other)</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="press-drop" id="slurry-other-dp" class="form-control text-data" value="0" step="any">
                      <span class="unit" data-unit-type="press-drop">bar</span>
                    </div>
                  </div>
                </div>
              </fieldset>
              <button type="submit" class="btn btn-primary btn-block" style="margin-top: var(--space-md);">
                <span class="btn-text">RUN SLURRY HYDRAULICS</span>
                <span class="btn-icon">⚡</span>
              </button>
            </form>
          </div>
        </div>
        
        <!-- Outputs Panel -->
    <div class="panel panel-output" style="position: relative;">
      <!-- Simulation Processing Overlay -->
      <div id="slurry-sim-overlay" class="sim-overlay">
        <div class="sim-spinner"></div>
        <div class="sim-title">Evaluating Slurry Hydraulics</div>
        <div class="sim-scanline"></div>
        <div class="sim-console-text">Solving heterogeneous solids transport...</div>
      </div>
      <div class="panel-header">
        <span class="panel-title">TECHNICAL EVALUATIONS DATASHEET — SLURRY LINE SIZING</span>
      </div>
      <div class="panel-body">
        <div id="slurry-results" class="results-container">
          <div class="results-layout-wrapper">
            <!-- Left Column: Visualizations & Warnings -->
            <div class="results-column-visual">
              <div class="iso-animation-wrapper" style="margin-top: 0;">
                <div class="chart-title" style="display: flex; justify-content: space-between; align-items: center;">
                  <span>3D PHYSICAL FLOW SIMULATION — SLURRY SECTION</span>
                  <button type="button" id="btn-anim-pause-slurry" class="sthe-collapse-btn" style="padding: 1px 6px; font-size: 9px; line-height: 1;">PAUSE</button>
                </div>
                <div id="slurry-3d-container" class="iso-animation-container" style="position: relative;">
                  <canvas id="slurry-animation-canvas" style="width: 100%; height: 100%; position: absolute; left:0; top:0;"></canvas>
                </div>
              </div>
              <div class="rec-panel" style="margin-top: var(--space-md);">
                <div class="rec-title">DEPOSITION CRITICALITY STATUS</div>
                <div class="rec-list">
                  <div id="slurry-dep-warning" class="rec-item ok">✓ Operating velocity is safe from deposition settling</div>
                </div>
              </div>
            </div>
            <!-- Right Column: Numeric Results -->
            <div class="results-column-data">
              <div class="results-grid">
                <div class="result-card">
                  <div class="card-label">Pipe Inside ID</div>
                  <div class="card-value"><span data-unit-type="length-mm" id="out-slurry-id-mm">0.0</span><span class="card-unit" data-unit-type="length-mm">mm</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Slurry Density</div>
                  <div class="card-value"><span data-unit-type="density" id="out-slurry-density">0.000</span><span class="card-unit" data-unit-type="density">kg/m³</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Slurry Viscosity</div>
                  <div class="card-value"><span data-unit-type="viscosity" id="out-slurry-viscosity">0.000</span><span class="card-unit" data-unit-type="viscosity">cP</span></div>
                </div>
              </div>
              <div class="results-grid" style="margin-top: var(--space-md);">
                <div class="result-card">
                  <div class="card-label">Deposition Velocity</div>
                  <div class="card-value text-teal"><span data-unit-type="velocity" id="out-slurry-vdep">0.00</span><span class="card-unit" data-unit-type="velocity">m/s</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Concentration (Cv)</div>
                  <div class="card-value"><span id="out-slurry-cv">0.0</span><span class="card-unit">%</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label font-bold">Line Velocity</div>
                  <div class="card-value"><span data-unit-type="velocity" id="out-slurry-velocity">0.00</span><span class="card-unit" data-unit-type="velocity">m/s</span></div>
                </div>
              </div>
              <div class="results-grid" style="margin-top: var(--space-md);">
                <div class="result-card">
                  <div class="card-label font-bold">Reynolds Number</div>
                  <div class="card-value"><span id="out-slurry-reynolds">0</span><span class="card-unit" id="out-slurry-regime">Laminar</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Friction Factor (f)</div>
                  <div class="card-value"><span id="out-slurry-f">0.00000</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Erosion Limit (API 14E)</div>
                  <div class="card-value"><span id="out-slurry-erosion">0.00</span><span class="card-unit" data-unit-type="velocity">m/s</span></div>
                </div>
              </div>
              <div class="results-grid" style="margin-top: var(--space-md);">
                <div class="result-card">
                  <div class="card-label">Friction Loss (Pipe)</div>
                  <div class="card-value"><span data-unit-type="press-drop" id="out-slurry-dp-pipe">0.0000</span><span class="card-unit" data-unit-type="press-drop">bar</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Fittings & Valves Loss</div>
                  <div class="card-value"><span data-unit-type="press-drop" id="out-slurry-dp-fittings">0.0000</span><span class="card-unit" data-unit-type="press-drop">bar</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Elevation Change Loss</div>
                  <div class="card-value"><span data-unit-type="press-drop" id="out-slurry-dp-elevation">0.0000</span><span class="card-unit" data-unit-type="press-drop">bar</span></div>
                </div>
              </div>
              <div class="results-grid" style="margin-top: var(--space-md);">
                <div class="result-card highlight">
                  <div class="card-label font-bold">TOTAL PRESSURE DROP</div>
                  <div class="card-value text-teal"><span data-unit-type="press-drop" id="out-slurry-dp-total">0.0000</span><span class="card-unit" data-unit-type="press-drop">bar</span></div>
                </div>
                <div class="result-card highlight">
                  <div class="card-label">Unit Loss Drop Rate</div>
                  <div class="card-value text-teal"><span data-unit-type="press-drop" id="out-slurry-dp-100m">0.000</span><span class="card-unit" data-unit-type="press-drop">bar/100m</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

    <!-- LINE SUB-TAB 5: TWO-PHASE SIZING -->
    <div id="line-twophase-content" class="line-type-content">
      <div class="sizing-grid">
        <!-- Left Column: Inputs -->
        <div class="panel panel-input" style="max-height: calc(100vh - 180px); overflow-y: auto; overflow-x: hidden;">
          <div class="panel-header">
            <span class="panel-title">DESIGN DATA METRICS — TWO-PHASE FLOW SIZING</span>
          </div>
          <div class="panel-body">
            <div class="digital-badge">Atmanirbhar Bharat Digitalization</div>
            <form id="tp-form">
              <input type="hidden" id="tp-service" value="two_phase">
              <fieldset class="form-group">
                <legend>Fluid Properties Configuration</legend>
                <div class="phase-section-label">▸ Liquid Phase</div>
                <div class="input-row">
                  <div class="input-cell">
                    <label for="tp-liquid-name">Liquid Fluid Name</label>
                    <input type="text" id="tp-liquid-name" class="form-control" value="Water">
                  </div>
                  <div class="input-cell">
                    <label for="tp-liquid-density">Liquid Density</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="density" id="tp-liquid-density" class="form-control text-data" value="1000" step="any" required>
                      <span class="unit" data-unit-type="density">kg/m³</span>
                    </div>
                  </div>
                </div>
                <div class="input-row" style="margin-top: var(--space-sm);">
                  <div class="input-cell">
                    <label for="tp-liquid-viscosity">Liquid Viscosity</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="viscosity" id="tp-liquid-viscosity" class="form-control text-data" value="1.0" step="any" required>
                      <span class="unit" data-unit-type="viscosity">cP</span>
                    </div>
                  </div>
                </div>
                <div class="phase-section-label" style="margin-top: var(--space-md);">▸ Gas Phase</div>
                <div class="input-row">
                  <div class="input-cell">
                    <label for="tp-gas-name">Gas Name</label>
                    <input type="text" id="tp-gas-name" class="form-control" value="Steam">
                  </div>
                  <div class="input-cell">
                    <label for="tp-gas-density">Gas Density</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="density" id="tp-gas-density" class="form-control text-data" value="2.5" step="any" required>
                      <span class="unit" data-unit-type="density">kg/m³</span>
                    </div>
                  </div>
                </div>
                <div class="input-row" style="margin-top: var(--space-sm);">
                  <div class="input-cell">
                    <label for="tp-gas-viscosity">Gas Viscosity</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="viscosity" id="tp-gas-viscosity" class="form-control text-data" value="0.018" step="any" required>
                      <span class="unit" data-unit-type="viscosity">cP</span>
                    </div>
                  </div>
                </div>
                <div class="input-row" style="margin-top: var(--space-md);">
                  <div class="input-cell">
                    <label for="tp-pressure">Operating Pressure</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="pressure" id="tp-pressure" class="form-control text-data" value="5.0" step="any" required>
                      <span class="unit" data-unit-type="pressure">bar A</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="tp-temp">Temperature</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="temperature" id="tp-temp" class="form-control text-data" value="150" step="any" required>
                      <span class="unit" data-unit-type="temperature">°C</span>
                    </div>
                  </div>
                </div>
                <div class="input-row" style="margin-top: var(--space-sm);">
                  <div class="input-cell">
                    <label for="tp-mass-flow">Total Mass Flowrate</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="mass-flow" id="tp-mass-flow" class="form-control text-data" value="10000" step="any" required>
                      <span class="unit" data-unit-type="mass-flow">kg/hr</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="tp-quality">Gas Quality / Vapour Fraction x (0–1)</label>
                    <div class="input-with-unit">
                      <input type="number" id="tp-quality" class="form-control text-data" value="0.1" step="0.01" min="0" max="1" required>
                      <span class="unit">x</span>
                    </div>
                  </div>
                </div>
              </fieldset>
              <fieldset class="form-group" style="margin-top: var(--space-md);">
                <legend>Pipeline Routing & Geometry</legend>
                <div class="input-grid-3">
                  <div class="input-cell">
                    <label for="tp-material">Pipe Material</label>
                    <div class="select-wrapper">
                      <select id="tp-material" class="form-control">
                        <option value="cs" selected>CS (Carbon Steel)</option>
                        <option value="ss">SS (Stainless Steel)</option>
                        <option value="pvc">PVC (Plastic)</option>
                        <option value="ci">Cast Iron</option>
                        <option value="concrete">Concrete</option>
                      </select>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="tp-roughness">Roughness (ε)</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="length-mm" id="tp-roughness" class="form-control text-data" value="0.045" step="any" required>
                      <span class="unit" data-unit-type="length-mm">mm</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="tp-nps">Nominal Size (NPS)</label>
                    <div class="select-wrapper">
                      <select id="tp-nps" class="form-control">
                        <option value="0.5">½"</option>
                        <option value="0.75">¾"</option>
                        <option value="1">1"</option>
                        <option value="1.5">1½"</option>
                        <option value="2">2"</option>
                        <option value="3">3"</option>
                        <option value="4" selected>4"</option>
                        <option value="6">6"</option>
                        <option value="8">8"</option>
                        <option value="10">10"</option>
                        <option value="12">12"</option>
                        <option value="14">14"</option>
                        <option value="16">16"</option>
                        <option value="18">18"</option>
                        <option value="20">20"</option>
                        <option value="24">24"</option>
                      </select>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="tp-schedule">Pipe Schedule</label>
                    <div class="select-wrapper">
                      <select id="tp-schedule" class="form-control">
                        <option value="STD">STD</option>
                        <option value="40" selected>40</option>
                        <option value="80">80</option>
                        <option value="160">160</option>
                      </select>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="tp-id">Auto-filled ID</label>
                    <div class="input-with-unit">
                      <input type="number" id="tp-id" class="form-control text-data" value="4.026" step="any" required>
                      <span class="unit">inches</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="tp-length">Pipe Route Length</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="length-m" id="tp-length" class="form-control text-data" value="100" step="any" required>
                      <span class="unit" data-unit-type="length-m">m</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="tp-elevation">Elevation Change (ΔZ)</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="length-m" id="tp-elevation" class="form-control text-data" value="0" step="any">
                      <span class="unit" data-unit-type="length-m">m</span>
                    </div>
                  </div>
                  <div class="input-cell">
                    <label for="tp-other-dp">Other Losses (ΔP_other)</label>
                    <div class="input-with-unit">
                      <input type="number" data-unit-type="press-drop" id="tp-other-dp" class="form-control text-data" value="0" step="any">
                      <span class="unit" data-unit-type="press-drop">bar</span>
                    </div>
                  </div>
                </div>
              </fieldset>
              <fieldset class="form-group" style="margin-top: var(--space-md);">
                <legend>Pipe Orientation</legend>
                <div class="radio-group">
                  <label><input type="radio" name="tp-orient" id="tp-orient-h" value="horizontal" checked> Horizontal</label>
                  <label style="margin-left: 20px;"><input type="radio" name="tp-orient" id="tp-orient-v" value="vertical"> Vertical</label>
                </div>
              </fieldset>
              <button type="submit" class="btn btn-primary btn-block" style="margin-top: var(--space-md);">
                <span class="btn-text">RUN TWO-PHASE CALCULATION</span>
                <span class="btn-icon">⚡</span>
              </button>
            </form>
      </div>
    </div>

    <!-- Outputs Panel -->
    <div class="panel panel-output" style="position: relative;">
      <!-- Simulation Processing Overlay -->
      <div id="tp-sim-overlay" class="sim-overlay">
        <div class="sim-spinner"></div>
        <div class="sim-title">Evaluating Two-Phase Sizing</div>
        <div class="sim-scanline"></div>
        <div class="sim-console-text">Solving Lockhart-Martinelli parameters...</div>
      </div>
      <div class="panel-header">
        <span class="panel-title">TECHNICAL EVALUATIONS DATASHEET — TWO-PHASE LINE SIZING</span>
      </div>
      <div class="panel-body">
        <div id="tp-results" class="results-container">
          <div class="results-layout-wrapper">
            <!-- Left Column: Visualizations & Warnings -->
            <div class="results-column-visual">
              <div class="iso-animation-wrapper" style="margin-top: 0;">
                <div class="chart-title" style="display: flex; justify-content: space-between; align-items: center;">
                  <span>3D PHYSICAL FLOW SIMULATION — TWO-PHASE SECTION</span>
                  <button type="button" id="btn-anim-pause-tp" class="sthe-collapse-btn" style="padding: 1px 6px; font-size: 9px; line-height: 1;">PAUSE</button>
                </div>
                <div id="tp-3d-container" class="iso-animation-container" style="position: relative;">
                  <canvas id="tp-animation-canvas" style="width: 100%; height: 100%; position: absolute; left:0; top:0;"></canvas>
                </div>
              </div>
              <div class="rec-panel" style="margin-top: var(--space-md);">
                <div class="rec-title">TWO-PHASE FLOW REGIME</div>
                <div class="rec-list">
                  <div id="out-tp-pattern" class="digital-badge" style="font-size: 14px; padding: 6px 12px; background: rgba(0, 196, 160, 0.1); color: var(--color-teal); border: 1px solid var(--color-teal); text-align: center; font-family: var(--font-mono);">Slug Flow</div>
                </div>
              </div>
            </div>
            <!-- Right Column: Numeric Results -->
            <div class="results-column-data">
              <div class="results-grid">
                <div class="result-card">
                  <div class="card-label">Liquid Velocity (V_SL)</div>
                  <div class="card-value"><span data-unit-type="velocity" id="out-tp-vl">0.00</span><span class="card-unit" data-unit-type="velocity">m/s</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Gas Velocity (V_SG)</div>
                  <div class="card-value"><span data-unit-type="velocity" id="out-tp-vg">0.00</span><span class="card-unit" data-unit-type="velocity">m/s</span></div>
                </div>
                <div class="result-card highlight">
                  <div class="card-label font-bold">Mixture Velocity (V_m)</div>
                  <div class="card-value text-teal"><span data-unit-type="velocity" id="out-tp-vm">0.00</span><span class="card-unit" data-unit-type="velocity">m/s</span></div>
                </div>
              </div>
              <div class="results-grid" style="margin-top: var(--space-md);">
                <div class="result-card">
                  <div class="card-label">Mixture Density</div>
                  <div class="card-value"><span data-unit-type="density" id="out-tp-mix-density">0.000</span><span class="card-unit" data-unit-type="density">kg/m³</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Martinelli parameter (X_tt)</div>
                  <div class="card-value"><span id="out-tp-xtt">0.00</span><span class="card-unit">Xtt</span></div>
                </div>
                <div class="result-card">
                  <div class="card-label">Two-Phase Multiplier (Φ_L²)</div>
                  <div class="card-value"><span id="out-tp-phi">0.00</span><span class="card-unit">Phi</span></div>
                </div>
              </div>
              <div class="results-grid" style="margin-top: var(--space-md);">
                <div class="result-card highlight">
                  <div class="card-label font-bold">Friction Drop (Two-Phase)</div>
                  <div class="card-value text-teal"><span data-unit-type="press-drop" id="out-tp-dp">0.0000</span><span class="card-unit" data-unit-type="press-drop">bar</span></div>
                </div>
                <div class="result-card highlight">
                  <div class="card-label">Unit Loss Drop Rate</div>
                  <div class="card-value text-teal"><span data-unit-type="press-drop" id="out-tp-dp-100m">0.000</span><span class="card-unit" data-unit-type="press-drop">bar/100m</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</section>

  <!-- TAB 3: SUMMARY REPORT -->
  <section id="report-tab" class="tab-content">
    <div class="report-container" style="padding: 10px;">
      <div class="panel">
        <div class="panel-header report-header-bar" style="display: flex; justify-content: space-between; align-items: center;">
          <span class="panel-title">BHARAT DIGITAL DATASHEET SUMMARY REPORT</span>
          <div style="display: flex; gap: var(--space-sm);">
            <button id="btn-download-pdf" class="btn btn-primary" style="padding: 4px 12px; font-size: 11px;">
              <span class="btn-text">DOWNLOAD PDF</span>
              <span class="btn-icon">⬇</span>
            </button>
            <button id="btn-copy-report" class="btn btn-secondary" style="padding: 4px 12px; font-size: 11px;">
              <span class="btn-text">COPY ALL RESULTS</span>
              <span class="btn-icon">📋</span>
            </button>
          </div>
        </div>
        <div class="panel-body">
          <!-- Report Content inside viewport -->
          <div id="report-viewport" class="report-viewport" style="background: var(--bg-input); border: 1px solid var(--border-muted); padding: var(--space-lg); border-radius: var(--radius-md); max-height: calc(100vh - 180px); overflow-y: auto;">
            <div class="report-paper">
              <div class="report-title" style="text-align: center; font-family: var(--font-mono); font-size: 14px; font-weight: 700; color: var(--color-saffron); margin-bottom: 20px;">BHARAT FLOWSIZE SYSTEM SIZING SUMMARY DATASHEET</div>
              <div class="report-meta" style="display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); border-bottom: 1px solid var(--border-muted); padding-bottom: 10px; margin-bottom: 20px;">
                <div>TIMESTAMP: <span id="report-time">-</span></div>
                <div>UNIT SYSTEM: <span id="report-unit-system">SI</span></div>
              </div>

              <div class="report-section-title" style="font-family: var(--font-mono); font-size: 11px; font-weight: 700; color: var(--color-saffron); margin-bottom: 8px;">1. PUMP HYDRAULICS PROFILE</div>
              <table class="report-table" style="width: 100%; border-collapse: collapse; margin-bottom: 20px; font-family: var(--font-mono); font-size: 10px; color: var(--text-main);">
                <tr>
                  <td class="lbl" style="padding: 4px 0; color: var(--text-muted); width: 35%;">Fluid Service:</td>
                  <td class="val text-data" id="rep-pump-fluid" style="padding: 4px 0; font-weight: 600; color: var(--text-header);">-</td>
                  <td class="lbl" style="padding: 4px 0; color: var(--text-muted); width: 35%;">Normal Temperature:</td>
