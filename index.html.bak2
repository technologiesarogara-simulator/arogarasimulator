                        <td style="padding: 4px 6px; color: var(--text-muted);">inches</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Pipe OD</td>
                        <td id="out-line-od" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td style="padding: 4px 6px; color: var(--text-muted);">inches / mm</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Nominal ID</td>
                        <td id="out-line-nominal-id" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td style="padding: 4px 6px; color: var(--text-muted);">mm</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Fluid</td>
                        <td id="out-line-fluid" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Operating Temperature (Normal)</td>
                        <td id="out-line-operating-temp" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td class="unit" data-unit-type="temperature" style="padding: 4px 6px; color: var(--text-muted);">°C</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Service Fluid Condition</td>
                        <td id="out-line-service" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Viscosity</td>
                        <td id="out-line-viscosity" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td class="unit" data-unit-type="viscosity" style="padding: 4px 6px; color: var(--text-muted);">cP</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Density</td>
                        <td id="out-line-density" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td class="unit" data-unit-type="density" style="padding: 4px 6px; color: var(--text-muted);">kg/m³</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Upstream Pressure</td>
                        <td id="out-line-upstream-press" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td class="unit" data-unit-type="pressure" style="padding: 4px 6px; color: var(--text-muted);">bar G</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Downstream Pressure</td>
                        <td id="out-line-downstream-press" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td class="unit" data-unit-type="pressure" style="padding: 4px 6px; color: var(--text-muted);">bar G</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Total Pressure Drop</td>
                        <td id="out-line-total-dp" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td class="unit" data-unit-type="press-drop" style="padding: 4px 6px; color: var(--text-muted);">bar</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">ΔP per 100m</td>
                        <td id="out-line-dp-per-100m" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td class="unit" data-unit-type="press-drop-rate" style="padding: 4px 6px; color: var(--text-muted);">bar/100m</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Mass Flowrate</td>
                        <td id="out-line-mass-flow" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td class="unit" data-unit-type="mass-flow" style="padding: 4px 6px; color: var(--text-muted);">kg/hr</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Design Volumetric Flow</td>
                        <td id="out-line-vol-flow" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td class="unit" data-unit-type="vol-flow" style="padding: 4px 6px; color: var(--text-muted);">m³/hr</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Line Velocity</td>
                        <td id="out-line-velocity" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td class="unit" data-unit-type="velocity" style="padding: 4px 6px; color: var(--text-muted);">m/s</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Reynolds Number</td>
                        <td id="out-line-reynolds" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Flow Behavior</td>
                        <td id="out-line-behavior" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Friction Factor (f)</td>
                        <td id="out-line-f-factor" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Relative Roughness (ε/D)</td>
                        <td id="out-line-rel-roughness" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Erosion Velocity (100% API 14E)</td>
                        <td id="out-line-v-erosion-100" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td class="unit" data-unit-type="velocity" style="padding: 4px 6px; color: var(--text-muted);">m/s</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Design Erosion Velocity (75%)</td>
                        <td id="out-line-v-erosion-design" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td class="unit" data-unit-type="velocity" style="padding: 4px 6px; color: var(--text-muted);">m/s</td>
                      </tr>
                      <tr>
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Erosion Condition</td>
                        <td id="out-line-erosion-cond" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--text-header);">-</td>
                        <td style="padding: 4px 6px; color: var(--text-muted);">—</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>

              <div style="margin-bottom: var(--space-md);">
                <div class="rec-title" style="color: var(--color-saffron); margin-bottom: 6px; font-weight: bold; font-size: 11px;">PRESSURE DROP BREAKDOWN</div>
                <div class="table-responsive" style="border: 1px solid var(--border-muted); border-radius: var(--radius-sm); overflow: hidden; background: var(--bg-input);">
                  <table class="report-table" style="width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 10px; color: var(--text-main);">
                    <thead>
                      <tr style="border-bottom: 2px solid var(--border-muted); background: rgba(255,255,255,0.02); text-align: left;">
                        <th style="padding: 4px 6px; font-weight: 600; color: var(--text-header); border-right: 1px solid var(--border-muted);">Component</th>
                        <th style="padding: 4px 6px; font-weight: 600; color: var(--text-header); border-right: 1px solid var(--border-muted); text-align: right; width: 100px;">Pa</th>
                        <th style="padding: 4px 6px; font-weight: 600; color: var(--text-header); width: 80px; text-align: right;"><span class="unit" data-unit-type="press-drop">bar</span></th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Major Loss (Darcy-Weisbach)</td>
                        <td id="out-line-dp-major-pa" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right;">-</td>
                        <td id="out-line-dp-major-bar" style="padding: 4px 6px; text-align: right; color: var(--text-header);">-</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Static Head (Elevation)</td>
                        <td id="out-line-dp-static-pa" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right;">-</td>
                        <td id="out-line-dp-static-bar" style="padding: 4px 6px; text-align: right; color: var(--text-header);">-</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Minor Loss (K method) <span id="lbl-minor-sum-k">ΣK=0.00</span></td>
                        <td id="out-line-dp-minor-pa" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right;">-</td>
                        <td id="out-line-dp-minor-bar" style="padding: 4px 6px; text-align: right; color: var(--text-header);">-</td>
                      </tr>
                      <tr style="border-bottom: 1px solid var(--border-muted);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted);">Other (Instruments/Vendor)</td>
                        <td id="out-line-dp-other-pa" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right;">-</td>
                        <td id="out-line-dp-other-bar" style="padding: 4px 6px; text-align: right; color: var(--text-header);">-</td>
                      </tr>
                      <tr style="border-top: 1px solid var(--border-muted); font-weight: bold; background: rgba(255,255,255,0.01);">
                        <td style="padding: 4px 6px; border-right: 1px solid var(--border-muted); color: var(--text-header);">TOTAL PRESSURE DROP</td>
                        <td id="out-line-dp-total-pa" style="padding: 4px 6px; border-right: 1px solid var(--border-muted); text-align: right; color: var(--color-teal);">-</td>
                        <td id="out-line-dp-total-bar" style="padding: 4px 6px; text-align: right; color: var(--color-teal);">-</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>

              <div>
                <div class="rec-title" style="color: var(--color-saffron); margin-bottom: 6px; font-weight: bold; font-size: 11px;">COMPLIANCE STATUS BADGES</div>
                <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                  <span id="badge-vel-min" class="badge badge-amber" style="font-size: 9px;">Vel vs Min: —</span>
                  <span id="badge-vel-max" class="badge badge-amber" style="font-size: 9px;">Vel vs Max: —</span>
                  <span id="badge-vel-rec" class="badge badge-amber" style="font-size: 9px;">Rec: —</span>
                  <span id="badge-dp-status" class="badge badge-amber" style="font-size: 9px;">ΔP: —</span>
                  <span id="badge-erosion-status" class="badge badge-amber" style="font-size: 9px;">Erosion: —</span>
                  <span id="badge-regime-status" class="badge badge-amber" style="font-size: 9px;">Flow: —</span>
                </div>
              </div>
            </div>
          </div>
          
          <!-- LINE SIZING DESIGN ASSISTANT — AUTO CORRECTION SUGGESTIONS -->
          <div id="line-assistant-panel" class="rec-panel" style="display: none; border-left: 4px solid var(--color-saffron); background: rgba(255, 117, 56, 0.05); margin-top: var(--space-md); padding: 12px var(--space-md); font-family: var(--font-mono); border-top: 1px solid rgba(255, 117, 56, 0.15); border-right: 1px solid rgba(255, 117, 56, 0.15); border-bottom: 1px solid rgba(255, 117, 56, 0.15); border-radius: var(--radius-sm);">
            <div style="color: var(--color-saffron); font-weight: bold; font-size: 11px; margin-bottom: 6px; display: flex; align-items: center; gap: var(--space-xs);">
              <span>⚠ LINE SIZING DESIGN ASSISTANT — AUTO CORRECTION SUGGESTIONS</span>
            </div>
            <div id="line-assistant-content" style="font-size: 10px; color: var(--text-main);">
              <!-- dynamic suggestions list -->
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

    <!-- LINE SUB-TAB 2: GAS SIZING -->
    
        <div id="line-gas-content" class="line-type-content" style="display: none;">
          <div class="sizing-grid">
            <!-- Left Column: Inputs -->
            <div class="panel panel-input" style="max-height: calc(100vh - 180px); overflow-y: auto; overflow-x: hidden;">
              <div class="panel-header">
                <span class="panel-title">DESIGN DATA METRICS — GAS PIPELINE SIZING</span>
              </div>
              <div class="panel-body">
                <form id="line-gas-form">
                  <fieldset class="form-group">
                    <legend>Identification Block</legend>
                    <div class="input-grid-3">
                      <div class="input-cell">
                        <label for="gas-pid">P&amp;ID No</label>
                        <input type="text" id="gas-pid" class="form-control text-data" placeholder="AB-">
                      </div>
                      <div class="input-cell">
                        <label for="gas-from">Line From</label>
                        <input type="text" id="gas-from" class="form-control text-data" placeholder="Tank">
                      </div>
                      <div class="input-cell">
                        <label for="gas-to">Line To</label>
                        <input type="text" id="gas-to" class="form-control text-data" placeholder="Pump">
                      </div>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Gas Physical Properties</legend>
                    <div class="input-grid-2">
                      <div class="input-cell">
                        <label for="gas-fluid">Fluid</label>
                        <select id="gas-fluid" class="form-control text-data" style="font-family: var(--font-mono);">
                          <option value="H2">Hydrogen (H₂)</option>
                          <option value="He">Helium (He)</option>
                          <option value="CH4">Methane (CH₄)</option>
                          <option value="C2H4">Ethylene (C₂H₄)</option>
                          <option value="N2">Nitrogen (N₂)</option>
                          <option value="CO">Carbon Monoxide (CO)</option>
                          <option value="Air">Air</option>
                          <option value="O2">Oxygen (O₂)</option>
                          <option value="H2S">Hydrogen Sulfide (H₂S)</option>
                          <option value="NH3">Ammonia (NH₃)</option>
                          <option value="CO2">Carbon Dioxide (CO₂)</option>
                          <option value="N2O">Nitrous Oxide (N₂O)</option>
                          <option value="C3H8">Propane (C₃H₈)</option>
                          <option value="SO2">Sulfur Dioxide (SO₂)</option>
                          <option value="C4H10">Butane (C₄H₁₀)</option>
                          <option value="Cl2">Chlorine (Cl₂)</option>
                          <option value="C5H12">Pentane (C₅H₁₂)</option>
                          <option value="C6H14">Hexane (C₆H₁₄)</option>
                          <option value="C2H6">Ethane (C₂H₆)</option>
                          <option value="iC4H10">i-Butane (i-C₄H₁₀)</option>
                          <option value="nC4H10">n-Butane (n-C₄H₁₀)</option>
                          <option value="iC5H12">i-Pentane (i-C₅H₁₂)</option>
                          <option value="nC5H12">n-Pentane (n-C₅H₁₂)</option>
                          <option value="User">User Defined</option>
                        </select>
                      </div>
                      <div class="input-cell">
                        <label for="gas-mw">Molecular Weight (MW)</label>
                        <div class="input-with-unit">
                          <input type="number" id="gas-mw" class="form-control text-data" value="2.016" step="any" required>
                          <span class="unit">kg/kmol</span>
                        </div>
                      </div>
                    </div>
                    <div class="input-grid-4" style="margin-top: var(--space-sm);">
                      <div class="input-cell">
                        <label for="gas-viscosity">Viscosity (μ)</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="viscosity" id="gas-viscosity" class="form-control text-data" value="0.0089" step="any" required>
                          <span class="unit" data-unit-type="viscosity">cP</span>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="gas-gamma">γ (Cp/Cv)</label>
                        <input type="number" id="gas-gamma" class="form-control text-data" value="1.41" step="any" required>
                      </div>
                      <div class="input-cell">
                        <label for="gas-z">Z Factor</label>
                        <input type="number" id="gas-z" class="form-control text-data" value="1.0" step="any" required>
                      </div>
                      <div class="input-cell">
                        <label for="gas-r">Gas Constant</label>
                        <div class="input-with-unit">
                          <input type="text" id="gas-r" class="form-control text-data" value="8314.46" readonly style="background: rgba(255,255,255,0.02); color: var(--text-muted);">
                          <span class="unit">J/kmol·K</span>
                        </div>
                      </div>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Operating Conditions</legend>
                    <div class="input-grid-4">
                      <div class="input-cell">
                        <label for="gas-temp-norm">Normal Temp</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="temperature" id="gas-temp-norm" class="form-control text-data" value="15" step="any" required>
                          <span class="unit" data-unit-type="temperature">°C</span>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="gas-temp-min">Min Temp</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="temperature" id="gas-temp-min" class="form-control text-data" value="20" step="any" required>
                          <span class="unit" data-unit-type="temperature">°C</span>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="gas-temp-max">Max Temp</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="temperature" id="gas-temp-max" class="form-control text-data" value="50" step="any" required>
                          <span class="unit" data-unit-type="temperature">°C</span>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="gas-upstream-press">Upstream Press</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="pressure" id="gas-upstream-press" class="form-control text-data" value="20" step="any" required>
                          <span class="unit" data-unit-type="pressure">bar G</span>
                        </div>
                      </div>
                    </div>
                    
                    <div style="margin-top: var(--space-md); padding: 8px; background: rgba(0, 196, 160, 0.05); border: 1px dashed var(--color-teal); border-radius: var(--radius-sm); text-align: center;">
                      <span style="color: var(--text-muted); font-size: 10px;">AUTO-CALCULATED GAS DENSITY AT OPERATING CONDITIONS:</span><br>
                      <span id="lbl-gas-density-kg" style="color: var(--color-teal); font-weight: bold; font-size: 13px;">- kg/m³</span>
                      <span style="color: var(--text-muted); margin: 0 8px;">|</span>
                      <span id="lbl-gas-density-lb" style="color: var(--color-teal); font-weight: bold; font-size: 13px;">- lb/ft³</span>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Pipe &amp; Flow Data</legend>
                    <div class="input-grid-3">
                      <div class="input-cell">
                        <label for="gas-nps">NPS Size</label>
                        <select id="gas-nps" class="form-control text-data" style="font-family: var(--font-mono);">
                          <option value="0.5">1/2"</option>
                          <option value="0.75">3/4"</option>
                          <option value="1">1"</option>
                          <option value="1.5">1 1/2"</option>
                          <option value="2">2"</option>
                          <option value="3" selected>3"</option>
                          <option value="4">4"</option>
                          <option value="6">6"</option>
                          <option value="8">8"</option>
                          <option value="10">10"</option>
                          <option value="12">12"</option>
                          <option value="14">14"</option>
                          <option value="16">16"</option>
                          <option value="18">18"</option>
                          <option value="20">20"</option>
                          <option value="24">24"</option>
                        </select>
                      </div>
                      <div class="input-cell">
                        <label for="gas-schedule">Schedule</label>
                        <select id="gas-schedule" class="form-control text-data" style="font-family: var(--font-mono);">
                          <option value="STD">STD</option>
                          <option value="20">20</option>
                          <option value="30">30</option>
                          <option value="40">40</option>
                          <option value="60">60</option>
                          <option value="80">80</option>
                          <option value="100">100</option>
                          <option value="120">120</option>
                          <option value="140">140</option>
                          <option value="160" selected>160</option>
                        </select>
                      </div>
                      <div class="input-cell">
                        <label for="gas-flow">Volumetric Flow</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="vol-flow" id="gas-flow" class="form-control text-data" value="250" step="any" required>
                          <span class="unit" data-unit-type="vol-flow">m³/hr</span>
                        </div>
                      </div>
                    </div>
                    
                    <div class="input-grid-2" style="margin-top: var(--space-sm);">
                      <div class="input-cell">
                        <label for="gas-material">Pipe Material</label>
                        <select id="gas-material" class="form-control text-data" style="font-family: var(--font-mono);">
                          <option value="0.045">CS/MS/Wrought Iron/Commercial Steel/Alloy Steel (0.045 mm)</option>
                          <option value="0.15">GI (0.15 mm)</option>
                          <option value="0.0015" selected>SS304/316/321/310/Duplex/Copper/Brass/PVC/Hastelloy/Monel (0.0015 mm)</option>
                          <option value="0.26">Cast Iron (0.26 mm)</option>
                          <option value="0.12">Asphalted Cast Iron (0.12 mm)</option>
                          <option value="0.30">Concrete (0.30 mm)</option>
                          <option value="0.90">Riveted Steel (0.90 mm)</option>
                          <option value="0.007">HDPE (0.007 mm)</option>
                          <option value="0.005">FRP (0.005 mm)</option>
                          <option value="0.001">PTFE Lined (0.001 mm)</option>
                          <option value="0.010">Rubber Lined (0.010 mm)</option>
                          <option value="User">User Defined</option>
                        </select>
                      </div>
                      <div class="input-cell">
                        <label for="gas-roughness">Roughness ε</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="roughness" id="gas-roughness" class="form-control text-data" value="0.0015" step="any" required>
                          <span class="unit" data-unit-type="roughness">mm</span>
                        </div>
                      </div>
                    </div>

                    <div style="margin-top: var(--space-md); padding: 8px; background: rgba(255, 255, 255, 0.02); border: 1px dashed var(--border-muted); border-radius: var(--radius-sm); font-size: 10px;">
                      <div style="display: flex; justify-content: space-between; color: var(--text-muted); margin-bottom: 4px;">
                        <span>Pipe OD: <span id="lbl-gas-od" class="text-data text-white" style="font-weight: bold;">-</span></span>
                        <span>Wall Thk: <span id="lbl-gas-thickness" class="text-data text-white" style="font-weight: bold;">-</span></span>
                        <span>Nominal ID: <span id="lbl-gas-nominal-id" class="text-data text-white" style="font-weight: bold;">-</span></span>
                      </div>
                      <div style="display: flex; justify-content: space-between; color: var(--text-muted);">
                        <span>Mass Flow: <span id="lbl-gas-mass-flow" class="text-data text-teal" style="font-weight: bold;">- kg/hr</span></span>
                        <span>Line Velocity: <span id="lbl-gas-velocity" class="text-data text-teal" style="font-weight: bold;">- m/s</span></span>
                      </div>
                    </div>
