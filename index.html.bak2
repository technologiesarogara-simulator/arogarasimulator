                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Erosional Velocity Parameters (API 14E)</legend>
                    <div class="input-grid-3">
                      <div class="input-cell" style="grid-column: span 2;">
                        <label for="line-c-factor">Empirical C-Factor</label>
                        <div class="select-wrapper">
                          <select id="line-c-factor" class="form-control">
                            <option value="100">Clean Fluids / Corrosive (C=100)</option>
                            <option value="125" selected>Continuous Service (C=125)</option>
                            <option value="150">Intermittent Service (C=150)</option>
                            <option value="200">Intermittent Service Max (C=200)</option>
                            <option value="250">Corrosive Resistant Alloys (C=250)</option>
                            <option value="122">General Pure Liquid (C=122)</option>
                            <option value="custom">User Defined</option>
                          </select>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="line-c-factor-val">C-Factor Value</label>
                        <input type="number" id="line-c-factor-val" class="form-control text-data" value="125" step="any" required>
                      </div>
                      <div class="input-cell" style="grid-column: span 1.5;">
                        <label for="line-set-point">Design Set Point (%)</label>
                        <div class="input-with-unit">
                          <input type="number" id="line-set-point" class="form-control text-data" value="75" step="any" required>
                          <span class="unit">%</span>
                        </div>
                      </div>
                    </div>
                  </fieldset>
