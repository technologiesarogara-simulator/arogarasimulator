              <div class="report-section-title gas-report-section" style="display: none; margin-top: 25px; font-family: var(--font-mono); font-size: 11px; font-weight: 700; color: var(--color-saffron); margin-bottom: 8px;">3. COMPLIANCE AUDIT VERDICTS &mdash; GAS</div>
              <table class="report-table gas-report-table" style="display: none; width: 100%; border-collapse: collapse; margin-bottom: 20px; font-family: var(--font-mono); font-size: 10px; color: var(--text-main);">
                <tr>
                  <td class="lbl" style="padding: 4px 0; color: var(--text-muted); width: 35%;">Velocity Compliance:</td>
                  <td class="val text-data font-bold" id="rep-audit-gas-velocity" style="padding: 4px 0; font-weight: 600; color: var(--text-header);">-</td>
                  <td class="lbl" style="padding: 4px 0; color: var(--text-muted); width: 35%;">Pressure Drop Compliance:</td>
