<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BHARAT FLOWSIZE — Digital Sizing Platform</title>
<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<!-- Inline Stylesheet (embedded for deployment reliability) -->
<style>
/* ==========================================================================
   BHARAT FLOWSIZE PRO — DIGITAL INDIA SIZING SUITE
   ========================================================================== */

@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap');

:root {
  /* Fonts */
  --font-ui: 'Outfit', sans-serif;
  --font-mono: 'IBM Plex Mono', monospace;

  /* Colors - Digital India Modern Palette */
  --bg-app: #03060f;
  --bg-panel: rgba(13, 22, 47, 0.75);
  --bg-input: #060b17;
  --border-muted: rgba(43, 89, 195, 0.18);
  --border-active: #ff7538;
  
  /* Indian Tricolor & Tech Accents */
  --color-saffron: #ff7538;   /* Saffron Sizing Accent */
  --color-white: #ffffff;     /* Pure Clean White */
  --color-green: #00b875;     /* Emerald Green Sizing Accent */
  --color-chakra: #2a52be;    /* Ashoka Royal Blue */
  
  /* Glows */
  --saffron-glow: rgba(255, 117, 56, 0.15);
  --green-glow: rgba(0, 184, 117, 0.15);
  --chakra-glow: rgba(42, 82, 190, 0.25);
  
  /* Feedback Badge Colors */
  --color-ok: #00b875;
  --bg-ok: rgba(0, 184, 117, 0.08);
  --border-ok: rgba(0, 184, 117, 0.25);

  --color-warn: #ff7538;
  --bg-warn: rgba(255, 117, 56, 0.08);
  --border-warn: rgba(255, 117, 56, 0.25);

  --color-fail: #ef4444;
  --bg-fail: rgba(239, 68, 68, 0.08);
  --border-fail: rgba(239, 68, 68, 0.25);

  /* Typography */
  --text-main: #b4c5e4;
  --text-muted: #5770a3;
  --text-header: #f8fafc;
  
  /* Layout Spacing */
  --space-xs: 4px;
  --space-sm: 8px;
  --space-md: 16px;
  --space-lg: 24px;
  
  /* Glassmorphism Details */
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --shadow-main: 0 8px 32px 0 rgba(0, 0, 0, 0.4);
  --transition-normal: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-fast: 0.15s ease;
}

/* --- Light Theme Variables --- */
body.light-theme {
  --bg-app: #f1f5f9;
  --bg-panel: rgba(255, 255, 255, 0.85);
  --bg-input: #ffffff;
  --border-muted: rgba(42, 82, 190, 0.12);
  --border-active: #ff7538;
  
  --saffron-glow: rgba(255, 117, 56, 0.1);
  --green-glow: rgba(0, 184, 117, 0.1);
  --chakra-glow: rgba(42, 82, 190, 0.15);
  
  --bg-ok: rgba(0, 184, 117, 0.05);
  --border-ok: rgba(0, 184, 117, 0.2);
  --bg-warn: rgba(255, 117, 56, 0.05);
  --border-warn: rgba(255, 117, 56, 0.2);
  --bg-fail: rgba(239, 68, 68, 0.05);
  --border-fail: rgba(239, 68, 68, 0.2);

  --text-main: #334155;
  --text-muted: #64748b;
  --text-header: #0f172a;
  
  --shadow-main: 0 10px 30px rgba(0, 0, 0, 0.03);
}

body.light-theme {
  background-image: 
    radial-gradient(at 10% 20%, rgba(255, 117, 56, 0.015) 0px, transparent 50%),
    radial-gradient(at 90% 10%, rgba(42, 82, 190, 0.025) 0px, transparent 50%),
    radial-gradient(at 50% 80%, rgba(0, 184, 117, 0.015) 0px, transparent 50%);
}

body.light-theme .terminal-header {
  background: rgba(255, 255, 255, 0.9);
  border-bottom: 1px solid var(--border-muted);
}

body.light-theme .terminal-nav {
  background-color: rgba(241, 245, 249, 0.95);
  border-bottom: 1px solid var(--border-muted);
}

body.light-theme .terminal-logs {
  background-color: rgba(241, 245, 249, 0.95);
  border-top: 1px solid var(--border-muted);
}

body.light-theme .logo-text {
  background: linear-gradient(135deg, var(--color-saffron) 30%, #0f172a 50%, var(--color-green) 70%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

body.light-theme .nav-tab.active {
  background: linear-gradient(to top, rgba(255, 117, 56, 0.03), transparent);
}

body.light-theme .sim-overlay {
  background-color: rgba(248, 250, 252, 0.9);
}

body.light-theme .sim-title {
  background: linear-gradient(90deg, var(--color-saffron), var(--color-chakra));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

body.light-theme .report-viewport {
  background-color: #ffffff;
  border-color: #cbd5e1;
}

body.light-theme .report-paper {
  color: #0f172a;
}

body.light-theme .report-table td {
  border-bottom: 1px solid #f1f5f9;
  color: #0f172a;
}

body.light-theme .highlight-row {
  background-color: #f8fafc;
}

/* --- Base & Scrollbars --- */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background-color: var(--bg-app);
  color: var(--text-main);
  font-family: var(--font-ui);
  font-size: 13px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  background-image: 
    radial-gradient(at 10% 20%, rgba(255, 117, 56, 0.02) 0px, transparent 50%),
    radial-gradient(at 90% 10%, rgba(42, 82, 190, 0.04) 0px, transparent 50%),
    radial-gradient(at 50% 80%, rgba(0, 184, 117, 0.02) 0px, transparent 50%);
  background-attachment: fixed;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Scrollbars */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
::-webkit-scrollbar-track {
  background: var(--bg-app);
}
::-webkit-scrollbar-thumb {
  background: var(--border-muted);
  border-radius: var(--radius-sm);
}
::-webkit-scrollbar-thumb:hover {
  background: var(--color-chakra);
}

.text-data {
  font-family: var(--font-mono) !important;
}

/* --- Sizing Container --- */
.terminal-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100vw;
}

/* --- Top Header --- */
.terminal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px var(--space-lg);
  background: rgba(8, 12, 28, 0.85);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border-muted);
  z-index: 10;
}

.header-logo {
  display: flex;
  align-items: center;
  gap: 10px;
}

.logo-icon {
  color: var(--color-chakra);
  filter: drop-shadow(0 0 8px var(--chakra-glow));
}

.logo-text {
  font-weight: 700;
  font-size: 16px;
  letter-spacing: 1.5px;
  color: var(--text-header);
  background: linear-gradient(135deg, var(--color-saffron) 30%, var(--color-white) 50%, var(--color-green) 70%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.logo-accent {
  font-size: 9px;
  font-weight: 600;
  color: var(--color-chakra);
  border: 1px solid rgba(42, 82, 190, 0.4);
  padding: 1px 4px;
  border-radius: 3px;
  letter-spacing: 0.5px;
  margin-left: 5px;
  -webkit-text-fill-color: var(--color-chakra);
}

.header-status {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  font-family: var(--font-mono);
  font-size: 11px;
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  color: var(--color-green);
}

.pulse-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background-color: var(--color-green);
  box-shadow: 0 0 8px var(--color-green);
}

.header-divider {
  width: 1px;
  height: 12px;
  background-color: var(--border-muted);
}

.header-time {
  color: var(--text-muted);
}

/* --- Indian Tricolor Accent bar --- */
.tricolor-stripe {
  height: 3px;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  z-index: 9;
}
.stripe-saffron { background-color: var(--color-saffron); }
.stripe-white { background-color: var(--color-white); }
.stripe-green { background-color: var(--color-green); }

/* --- Tab Navigation System --- */
.terminal-nav {
  display: flex;
  background-color: rgba(6, 11, 26, 0.9);
  border-bottom: 1px solid var(--border-muted);
  padding-left: var(--space-lg);
  gap: var(--space-xs);
}

.nav-tab {
  background: none;
  border: none;
  color: var(--text-muted);
  font-family: var(--font-ui);
  font-size: 12px;
  font-weight: 600;
  padding: 12px var(--space-lg);
  cursor: pointer;
  transition: all var(--transition-normal);
  border-bottom: 3px solid transparent;
  display: flex;
  align-items: center;
  gap: 6px;
  letter-spacing: 0.5px;
}

.nav-tab:hover {
  color: var(--text-header);
}

.nav-tab.active {
  color: var(--text-header);
  border-bottom: 3px solid var(--color-saffron);
  background: linear-gradient(to top, rgba(255, 117, 56, 0.05), transparent);
}

.tab-num {
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--color-chakra);
}

/* --- Workspace Area --- */
.terminal-main {
  flex: 1;
  overflow-y: auto;
  padding: var(--space-lg);
}

.tab-content {
  display: none;
  height: 100%;
  animation: slide-up var(--transition-normal);
}

.tab-content.active {
  display: block;
}

@keyframes slide-up {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* --- Responsive Sizing Grid --- */
.sizing-grid {
  display: grid;
  grid-template-columns: 460px 1fr;
  gap: var(--space-lg);
  align-items: start;
}

@media (max-width: 1150px) {
  .sizing-grid {
    grid-template-columns: 1fr;
  }
}

/* --- Glassmorphic Panels --- */
.panel {
  background: var(--bg-panel);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--border-muted);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-main);
  overflow: hidden;
  transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
  position: relative;
}

.panel:hover {
  border-color: rgba(37, 99, 235, 0.25);
  box-shadow: 0 10px 40px 0 rgba(0, 0, 0, 0.45);
}

.panel-header {
  background: rgba(255, 255, 255, 0.01);
  border-bottom: 1px solid var(--border-muted);
  padding: var(--space-md) var(--space-lg);
}

.panel-title {
  font-family: var(--font-ui);
  font-size: 12px;
  font-weight: 700;
  color: var(--text-header);
  letter-spacing: 1px;
  text-transform: uppercase;
  background: linear-gradient(90deg, var(--text-header), var(--text-muted));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.panel-body {
  padding: var(--space-lg);
}

/* --- Indian Digitalization Badges --- */
.digital-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  background-color: rgba(42, 82, 190, 0.1);
  border: 1px solid rgba(42, 82, 190, 0.2);
  color: var(--text-main);
  padding: 3px 8px;
  border-radius: 12px;
  font-size: 10px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: var(--space-md);
}

.digital-badge::before {
  content: "🇮🇳";
}

/* --- High-tech form styling --- */
.form-group {
  border: 1px solid var(--border-muted);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-bottom: var(--space-lg);
  background-color: rgba(6, 11, 26, 0.4);
}

.form-group legend {
  font-family: var(--font-ui);
  font-size: 11px;
  font-weight: 700;
  color: var(--color-saffron);
  padding: 0 var(--space-sm);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.input-row {
  margin-bottom: var(--space-md);
}

.input-row:last-child {
  margin-bottom: 0;
}

.input-grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.input-grid-3 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

@media (max-width: 550px) {
  .input-grid-2, .input-grid-3 {
    grid-template-columns: 1fr;
    gap: var(--space-sm);
  }
}

.input-cell {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

label {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.form-control {
  background-color: var(--bg-input);
  border: 1px solid var(--border-muted);
  border-radius: var(--radius-sm);
  color: var(--text-header);
  font-family: var(--font-ui);
  font-size: 13px;
  padding: 6px 12px;
  width: 100%;
  height: 32px;
  outline: none;
  transition: all var(--transition-fast);
}

.form-control:focus {
  border-color: var(--color-saffron);
  box-shadow: 0 0 10px var(--saffron-glow);
}

/* Custom selects */
.select-wrapper {
  position: relative;
}

.select-wrapper select {
  appearance: none;
  -webkit-appearance: none;
  padding-right: 28px;
  cursor: pointer;
}

.select-wrapper::after {
  content: "▾";
  font-size: 12px;
  color: var(--text-muted);
  position: absolute;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
}

.select-wrapper:focus-within::after {
  color: var(--color-saffron);
}

/* Inputs with inline unit tags */
.input-with-unit {
  position: relative;
  display: flex;
  align-items: center;
}

.input-with-unit .form-control {
  padding-right: 54px;
}

.input-with-unit .unit {
  position: absolute;
  right: 12px;
  font-family: var(--font-ui);
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  pointer-events: none;
  background-color: var(--bg-input);
  padding-left: 4px;
}

/* --- High-tech buttons --- */
.btn {
  border: 1px solid transparent;
  border-radius: var(--radius-sm);
  font-family: var(--font-ui);
  font-size: 12px;
  font-weight: 700;
  padding: 10px 18px;
  cursor: pointer;
  transition: all var(--transition-normal);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
  height: 36px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.btn-block {
  display: flex;
  width: 100%;
}

.btn-primary {
  background-color: rgba(255, 117, 56, 0.08);
  border-color: var(--color-saffron);
  color: var(--color-saffron);
}

.btn-primary:hover {
  background-color: var(--color-saffron);
  color: var(--bg-app);
  box-shadow: 0 0 15px var(--saffron-glow);
}

.btn-primary:active {
  transform: scale(0.98);
}

.btn-secondary {
  background-color: rgba(255, 255, 255, 0.02);
  border-color: var(--border-muted);
  color: var(--text-main);
}

.btn-secondary:hover {
  background-color: rgba(255, 255, 255, 0.05);
  border-color: var(--text-muted);
  color: var(--text-header);
}

/* --- Sizing Output Panel Cards --- */
.results-container {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.status-banner {
  border-radius: var(--radius-md);
  padding: var(--space-sm) var(--space-md);
  display: flex;
  align-items: center;
  gap: var(--space-md);
  border: 1px solid transparent;
  backdrop-filter: blur(10px);
}

.banner-teal { background-color: var(--bg-ok); border-color: var(--border-ok); }
.banner-amber { background-color: var(--bg-warn); border-color: var(--border-warn); }
.banner-red { background-color: var(--bg-fail); border-color: var(--border-fail); }

.banner-badge {
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: var(--radius-sm);
  background-color: var(--bg-input);
  border: 1px solid var(--border-muted);
  letter-spacing: 0.5px;
}

.banner-teal .banner-badge { color: var(--color-ok); border-color: var(--border-ok); }
.banner-amber .banner-badge { color: var(--color-warn); border-color: var(--border-warn); }
.banner-red .banner-badge { color: var(--color-fail); border-color: var(--border-fail); }

.banner-message {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
}

.banner-teal .banner-message { color: var(--color-ok); }
.banner-amber .banner-message { color: var(--color-warn); }
.banner-red .banner-message { color: var(--color-fail); }

.results-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-md);
}

@media (max-width: 500px) {
  .results-grid {
    grid-template-columns: 1fr;
  }
}

.result-card {
  background-color: rgba(255, 255, 255, 0.01);
  border: 1px solid var(--border-muted);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 80px;
  transition: all var(--transition-normal);
}

.result-card:hover {
  background-color: rgba(255, 255, 255, 0.02);
  border-color: rgba(37, 99, 235, 0.25);
  transform: translateY(-2px);
}

.result-card.highlight {
  background: radial-gradient(circle at top left, rgba(255, 117, 56, 0.04), transparent);
  border-color: rgba(255, 117, 56, 0.25);
}

.card-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.card-value {
  font-family: var(--font-mono);
  font-size: 20px;
  font-weight: 700;
  color: var(--text-header);
}

.card-unit {
  font-size: 11px;
  color: var(--text-muted);
  margin-left: 2px;
}

.text-teal { color: var(--color-ok) !important; text-shadow: 0 0 8px var(--green-glow); }
.text-amber { color: var(--color-warn) !important; text-shadow: 0 0 8px var(--saffron-glow); }
.text-red { color: var(--color-fail) !important; }

/* --- Section Dividers --- */
.analysis-section {
  border: 1px solid var(--border-muted);
  border-radius: var(--radius-md);
  background-color: rgba(6, 11, 26, 0.4);
  padding: var(--space-md);
}

.analysis-header {
  font-family: var(--font-ui);
  font-size: 11px;
  font-weight: 700;
  color: var(--text-muted);
  letter-spacing: 1px;
  margin-bottom: var(--space-md);
  border-bottom: 1px solid var(--border-muted);
  padding-bottom: 4px;
  text-transform: uppercase;
}

/* --- Clean Scientific Slider/Scale (NPSH Comparison) --- */
.bar-gauge-container {
  margin-bottom: var(--space-xs);
}

.bar-labels {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: var(--text-muted);
  margin-bottom: 4px;
}

.bar-labels strong {
  font-family: var(--font-mono);
  color: var(--text-header);
}

.gauge-track {
  position: relative;
  height: 5px;
  background-color: var(--border-muted);
  border-radius: var(--radius-sm);
  margin-bottom: 20px;
}

.gauge-bar {
  height: 100%;
  border-radius: var(--radius-sm);
  transition: width 0.3s ease;
}

.gauge-marker {
  position: absolute;
  top: -6px;
  height: 17px;
  width: 2px;
  background-color: var(--text-header);
}

.gauge-marker.border-dashed {
  background-color: transparent;
  border-left: 2px dashed var(--text-muted);
}

.marker-label {
  position: absolute;
  top: 18px;
  transform: translateX(-50%);
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--text-muted);
  white-space: nowrap;
}

.badge-status-row {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-top: var(--space-sm);
}

.badge-title {
  font-size: 12px;
  color: var(--text-muted);
}

.badge {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: var(--radius-sm);
}

.badge-teal { color: var(--color-ok); background-color: var(--bg-ok); border-color: var(--border-ok); }
.badge-amber { color: var(--color-warn); background-color: var(--bg-warn); border-color: var(--border-warn); }
.badge-red { color: var(--color-fail); background-color: var(--bg-fail); border-color: var(--border-fail); }

/* --- Strict Engineering Fittings Table --- */
.fittings-table-container {
  border: 1px solid var(--border-muted);
  border-radius: var(--radius-md);
  overflow-y: auto;
  max-height: 180px;
}

.terminal-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}

.terminal-table th, .terminal-table td {
  padding: 6px 12px;
  border-bottom: 1px solid var(--border-muted);
}

.terminal-table th {
  background-color: rgba(6, 11, 26, 0.8);
  color: var(--text-muted);
  font-weight: 700;
  text-transform: uppercase;
  font-size: 10px;
  letter-spacing: 0.5px;
  position: sticky;
  top: 0;
  z-index: 1;
}

.terminal-table tr:hover {
  background-color: rgba(255, 255, 255, 0.015);
}

.table-input {
  background-color: var(--bg-input);
  border: 1px solid var(--border-muted);
  border-radius: var(--radius-sm);
  color: var(--text-header);
  font-family: var(--font-mono);
  font-size: 12px;
  padding: 2px 6px;
  width: 100%;
  text-align: center;
  outline: none;
  height: 24px;
}

.table-input:focus {
  border-color: var(--color-saffron);
}

/* --- Pressure Loss Breakdown --- */
.breakdown-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.breakdown-row {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
}

.breakdown-lbl { color: var(--text-muted); }
.breakdown-val { color: var(--text-header); }

.breakdown-divider {
  height: 1px;
  background-color: var(--border-muted);
  margin: 4px 0;
}

.total-row {
  font-size: 13px;
  font-weight: 700;
}

.total-row .breakdown-lbl { color: var(--text-header); }

/* --- Design Compliance Checklist --- */
.verifications-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.check-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) var(--space-md);
  background-color: rgba(6, 11, 26, 0.3);
  border: 1px solid var(--border-muted);
  border-radius: var(--radius-md);
}

.check-info {
  display: flex;
  flex-direction: column;
}

.check-name {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-header);
}

.check-details {
  font-size: 11px;
  color: var(--text-muted);
  font-family: var(--font-mono);
}

/* --- Charts Containers --- */
.chart-container-wrapper {
  background-color: rgba(6, 11, 26, 0.4);
  border: 1px solid var(--border-muted);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-top: var(--space-md);
  position: relative;
}

.chart-title {
  font-size: 11px;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: var(--space-sm);
  border-bottom: 1px solid var(--border-muted);
  padding-bottom: 4px;
}

/* --- 3D Isometric Animation Components --- */
.iso-animation-wrapper {
  background-color: rgba(6, 11, 26, 0.4);
  border: 1px solid var(--border-muted);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-top: var(--space-md);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.iso-animation-container {
  width: 100%;
  height: 180px;
  border-radius: var(--radius-sm);
  background-color: rgba(3, 6, 15, 0.3);
  overflow: hidden;
  position: relative;
  cursor: grab;
}

.iso-animation-container:active {
  cursor: grabbing;
}

/* Report charts formatting */
.report-charts-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-md);
  margin-top: 15px;
  margin-bottom: var(--space-lg);
}

.report-chart-box {
  background: rgba(255, 255, 255, 0.01);
  border: 1px solid var(--border-muted);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  height: 220px;
  position: relative;
}

.report-chart-box .chart-title {
  font-size: 9px;
  font-weight: 700;
  color: var(--text-muted);
  letter-spacing: 0.5px;
  border-bottom: 1px solid var(--border-muted);
  padding-bottom: 4px;
  margin-bottom: 8px;
  text-transform: uppercase;
}

@media (max-width: 650px) {
  .report-charts-grid {
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }
}

/* Liquid level animation */
.tank-liquid {
  transition: y 0.5s ease, height 0.5s ease;
}

/* --- Simulation Overlay System --- */
.sim-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(3, 6, 15, 0.9);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 5;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: var(--space-md);
  border-radius: var(--radius-lg);
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--transition-normal);
}

.sim-overlay.active {
  opacity: 1;
  pointer-events: auto;
}

.sim-spinner {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  border: 2px solid var(--border-muted);
  border-top-color: var(--color-saffron);
  border-bottom-color: var(--color-green);
  animation: spin-clockwise 1s linear infinite;
}

.sim-title {
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--text-header);
  background: linear-gradient(90deg, var(--color-saffron), var(--color-green));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-transform: uppercase;
}

.sim-scanline {
  width: 80%;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--color-chakra), transparent);
  position: relative;
  overflow: hidden;
}

.sim-scanline::after {
  content: ";
  position: absolute;
  width: 40px;
  height: 100%;
  background: var(--color-white);
  box-shadow: 0 0 10px var(--color-white);
  animation: scan 1.5s ease-in-out infinite;
}

@keyframes scan {
  0% { left: -10%; }
  100% { left: 110%; }
}

.sim-console-text {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--color-green);
}

/* --- Summary Report Tab --- */
.report-container {
  max-width: 900px;
  margin: 0 auto;
}

.report-header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.report-viewport {
  background-color: #040812;
  border: 1px solid var(--border-muted);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: var(--shadow-main);
}

.report-paper {
  font-family: var(--font-mono);
  color: var(--text-main);
  font-size: 12px;
}

.report-title {
  font-family: var(--font-ui);
  font-size: 16px;
  font-weight: 700;
  color: var(--text-header);
  text-align: center;
  margin-bottom: var(--space-md);
  letter-spacing: 1px;
  border-bottom: 2px dashed var(--border-muted);
  padding-bottom: var(--space-md);
}

.report-meta {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: var(--text-muted);
  margin-bottom: var(--space-lg);
  border-bottom: 1px solid var(--border-muted);
  padding-bottom: var(--space-xs);
}

.report-section-title {
  font-family: var(--font-ui);
  font-weight: 700;
  font-size: 13px;
  color: var(--color-saffron);
  border-bottom: 1px solid var(--border-muted);
  padding-bottom: 4px;
  margin-bottom: var(--space-sm);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.report-table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: var(--space-lg);
}

.report-table td {
  padding: 6px 8px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.02);
}

.report-table .lbl {
  color: var(--text-muted);
  width: 35%;
}

.report-table .val {
  color: var(--text-header);
  width: 15%;
}

.highlight-row {
  background-color: rgba(255, 255, 255, 0.01);
  border-top: 1px solid var(--border-muted);
  border-bottom: 1px solid var(--border-muted);
}

.highlight-row td {
  padding: 8px;
}

.font-bold {
  font-weight: 700;
}

.report-footer {
  text-align: center;
  font-size: 10px;
  color: var(--text-muted);
  border-top: 1px dashed var(--border-muted);
  margin-top: 30px;
  padding-top: var(--space-sm);
}

/* --- Clean Professional Status Bar --- */
.terminal-logs {
  background-color: rgba(8, 12, 28, 0.9);
  backdrop-filter: blur(10px);
  border-top: 1px solid var(--border-muted);
  padding: 6px var(--space-lg);
  font-size: 11px;
  color: var(--text-muted);
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 28px;
  user-select: none;
}

.logs-header {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.logs-title {
  font-family: var(--font-ui);
  font-weight: 700;
  font-size: 10px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 1px;
}

.logs-status-val {
  color: var(--color-saffron);
  font-family: var(--font-mono);
  font-weight: 600;
}

/* Hide legacy console rows */
.logs-body, .logs-toggle-btn {
  display: none !important;
}

.animate-fade-in {
  animation: fade-in var(--transition-normal);
}

/* --- PDF Print Specific Adjustments --- */
@media print {
  body {
    background: #ffffff !important;
    color: #000000 !important;
  }
  .report-viewport {
    background-color: #ffffff !important;
    border: none !important;
    box-shadow: none !important;
    color: #000000 !important;
  }
  .report-paper {
    color: #000000 !important;
  }
  .report-table td {
    border-bottom: 1px solid #e2e8f0 !important;
    color: #000000 !important;
  }
  .report-table .lbl {
    color: #475569 !important;
  }
  .report-table .val {
    color: #000000 !important;
  }
  .highlight-row {
    background-color: #f1f5f9 !important;
    border-top: 1px solid #cbd5e1 !important;
    border-bottom: 1px solid #cbd5e1 !important;
  }
  .report-section-title {
    color: #0f172a !important;
    border-bottom: 2px solid #0f172a !important;
  }
  .text-teal, .text-saffron, .text-green {
    color: #000000 !important;
  }
}

/* --- Theme Toggle Button --- */
.theme-toggle-btn {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--border-muted);
  color: var(--text-main);
  border-radius: var(--radius-sm);
  width: 30px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.theme-toggle-btn:hover {
  background: rgba(255, 255, 255, 0.08);
  border-color: var(--color-saffron);
  color: var(--color-saffron);
  box-shadow: 0 0 10px var(--saffron-glow);
  transform: translateY(-1px);
}

body.light-theme .theme-toggle-btn {
  background: rgba(15, 23, 42, 0.02);
}
body.light-theme .theme-toggle-btn:hover {
  background: rgba(15, 23, 42, 0.05);
}

/* --- 3D Dashboard Perspective Tilt --- */
.panel {
  transform: perspective(1000px) rotateX(0deg) rotateY(0deg);
  transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1), border-color var(--transition-normal), box-shadow var(--transition-normal);
}

.panel:hover {
  transform: perspective(1000px) translateY(-3px) rotateX(0.6deg) rotateY(-0.3deg);
}

.result-card {
  transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), background-color var(--transition-normal), border-color var(--transition-normal);
}

.result-card:hover {
  transform: translateY(-2px) scale(1.015);
}

/* --- Dual Column Output Layout --- */
.results-layout-wrapper {
  display: grid;
  grid-template-columns: 1fr 1.15fr;
  gap: var(--space-lg);
  align-items: start;
  margin-top: var(--space-md);
}

.results-column-visual {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.results-column-data {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

@media (max-width: 1024px) {
  .results-layout-wrapper {
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }
}
  /* Shell & Tube Heat Exchanger Styles */
  .sthe-grid {
    display: grid;
    grid-template-columns: 480px 1fr;
    gap: var(--space-lg);
    align-items: start;
  }
  @media (max-width: 1150px) {
    .sthe-grid { grid-template-columns: 1fr; }
  }
  .sthe-section-header {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--color-saffron);
    letter-spacing: 1.2px;
    text-transform: uppercase;
    padding: var(--space-xs) 0;
    margin: var(--space-md) 0 var(--space-sm);
    border-bottom: 1px solid rgba(255, 117, 56, 0.2);
  }
  .sthe-input-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
  }
  @media (max-width: 600px) {
    .sthe-input-pair { grid-template-columns: 1fr; }
  }
  .sthe-input-pair .input-cell label {
    font-size: 10px;
  }
  .sthe-toggle-group {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin: var(--space-sm) 0;
  }
  .sthe-toggle-group label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
  }
  .sthe-toggle-group select.form-control {
    max-width: 200px;
  }
  .sthe-info-panel {
    background: rgba(6, 11, 26, 0.5);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-md);
    margin: var(--space-sm) 0;
    overflow: hidden;
  }
  .sthe-info-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    cursor: pointer;
    user-select: none;
  }
  .sthe-info-panel-header span {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .sthe-collapse-btn {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-saffron);
    background: none;
    border: 1px solid rgba(255, 117, 56, 0.25);
    border-radius: var(--radius-sm);
    padding: 2px 8px;
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .sthe-collapse-btn:hover {
    background: rgba(255, 117, 56, 0.1);
  }
  .sthe-info-panel-body {
    padding: 0 var(--space-md) var(--space-md);
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1.7;
    color: var(--text-muted);
  }
  .sthe-info-panel-body table {
    width: 100%;
    border-collapse: collapse;
  }
  .sthe-info-panel-body table td {
    padding: 3px 6px;
    border-bottom: 1px solid rgba(43, 89, 195, 0.08);
    font-size: 10px;
  }
  .sthe-info-panel-body table td:first-child {
    color: var(--text-main);
    white-space: nowrap;
  }
  .sthe-info-panel-body table td:last-child {
    text-align: right;
    color: var(--text-header);
    font-weight: 600;
  }
  .sthe-rec-panel {
    background: rgba(6, 11, 26, 0.3);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    margin-top: var(--space-md);
  }
  .sthe-rec-title {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-saffron);
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
  }
  .sthe-rec-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .sthe-rec-item {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .sthe-rec-item.ok { color: var(--color-ok); }
  .sthe-rec-item.warn { color: var(--color-warn); }
  .sthe-rec-item.fail { color: var(--color-fail); }

  /* Light Theme STHE Overrides */
  body.light-theme .sthe-info-panel {
    background: rgba(241, 245, 249, 0.6);
  }
  body.light-theme .sthe-section-header {
    border-color: rgba(255, 117, 56, 0.15);
  }
  body.light-theme .sthe-rec-panel {
    background: rgba(241, 245, 249, 0.5);
  }
  body.light-theme .sthe-collapse-btn {
    border-color: rgba(255, 117, 56, 0.2);
  }
  body.light-theme .sthe-info-panel-body table td {
    border-color: rgba(15, 23, 42, 0.06);
  }
font-family: var(--font-mono);
font-size: 11px;
padding: 5px 6px;
border-bottom: 1px solid rgba(43, 89, 195, 0.08);
}
.sthe-summary-table td.lbl {
color: var(--text-muted);
}
.sthe-summary-table td.val {
color: var(--text-header);
font-weight: 600;
}

/* Light theme overrides */
body.light-theme .sthe-info-panel {
background: rgba(241, 245, 249, 0.6);
}
body.light-theme .sthe-section-header {
border-color: rgba(255, 117, 56, 0.15);
}
body.light-theme .sthe-rec-panel {
background: rgba(241, 245, 249, 0.5);
}
body.light-theme .sthe-collapse-btn {
border-color: rgba(255, 117, 56, 0.2);
}
body.light-theme .sthe-info-panel-body table td {
border-color: rgba(15, 23, 42, 0.06);
}


/* =========================================================
   PUMP SIZING TRUE 2-COLUMN LAYOUT & SMART TABLES (PREMIUM)
========================================================= */
.pump-layout-grid {
    display: grid;
    grid-template-columns: 480px 1fr;
    gap: 24px;
    width: 100%;
    margin: 0 auto;
}
@media (min-width: 1440px) { .pump-layout-grid { grid-template-columns: 500px 1fr; } }
@media (max-width: 1023px) { .pump-layout-grid { grid-template-columns: 1fr; } }

.sizing-panel.pump-left-panel {
    height: 100vh;
    overflow-y: auto;
    border-right: 1px solid rgba(245, 158, 11, 0.2);
    background: linear-gradient(180deg, #050d05 0%, #030803 100%);
    position: relative;
    padding-right: 12px;
}
.sizing-panel.pump-left-panel::-webkit-scrollbar { width: 6px; }
.sizing-panel.pump-left-panel::-webkit-scrollbar-track { background: #050d05; }
.sizing-panel.pump-left-panel::-webkit-scrollbar-thumb { background: rgba(245, 158, 11, 0.4); border-radius: 3px; }

/* Zone A: Badge Bar */
.pump-badge-bar {
    width: 100%;
    height: auto;
    min-height: 56px;
    background: rgba(10, 26, 10, 0.6);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(245, 158, 11, 0.3);
    display: flex;
    align-items: center;
    justify-content: space-around;
    padding: 10px 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
}
.pump-badge-bar .top-pill {
    background: rgba(13, 31, 13, 0.8);
    border: 1px solid rgba(245,158,11,0.5);
    border-radius: 20px;
    padding: 6px 16px;
    display: flex;
    align-items: baseline;
    gap: 8px;
    box-shadow: 0 0 12px rgba(245,158,11,0.15);
    transition: all 0.3s ease;
}
.pump-badge-bar .top-pill:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(245,158,11,0.3);
    border-color: #f59e0b;
}
.pump-badge-bar .lbl { font-family: var(--font-mono); font-size: 0.85rem; font-variant: small-caps; color: #4ade80; opacity: 0.9; }
.pump-badge-bar .val { font-family: var(--font-mono); font-size: 1.1rem; font-weight: 700; color: #ffffff; text-shadow: 0 0 8px rgba(255,255,255,0.3); }
.pump-badge-bar .unt { font-family: var(--font-mono); font-size: 0.75rem; color: rgba(255,255,255,0.5); }

/* Zone B: Output Cards Grid */
.pump-results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    padding: 0 16px 24px 16px;
    width: 100%;
}
@media (min-width: 1440px) { .pump-results-grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 1023px) { .pump-results-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 599px) { .pump-results-grid { grid-template-columns: 1fr; } }

.pump-res-card {
    background: rgba(13, 31, 13, 0.4);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(74, 222, 128, 0.1);
    border-radius: 12px;
    padding: 20px;
    min-height: 110px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.pump-res-card:hover {
    background: rgba(13, 31, 13, 0.7);
    border-color: rgba(74, 222, 128, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
}
.pump-res-card .res-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #4ade80;
    opacity: 0.8;
    margin-bottom: 12px;
}
.pump-res-card .res-value {
    font-family: var(--font-mono);
    font-size: 1.6rem;
    font-weight: 700;
    color: #f1f5f9;
    line-height: 1;
    word-break: break-all;
    white-space: pre-wrap;
}
.pump-res-card .res-unit {
    font-size: 1rem;
    font-weight: 400;
    color: rgba(255,255,255,0.4);
    margin-left: 4px;
}

/* Highlighted Cards */
.pump-res-card.highlight-card {
    background: linear-gradient(135deg, rgba(20, 30, 15, 0.8) 0%, rgba(10, 15, 5, 0.9) 100%);
    border: 1px solid rgba(245, 158, 11, 0.5);
    box-shadow: 0 8px 32px rgba(245, 158, 11, 0.15), inset 0 0 20px rgba(245, 158, 11, 0.05);
}
.pump-res-card.highlight-card:hover {
    box-shadow: 0 12px 40px rgba(245, 158, 11, 0.25), inset 0 0 30px rgba(245, 158, 11, 0.1);
    border-color: #f59e0b;
}
.pump-res-card.highlight-card .res-label { color: #fcd34d; }
.pump-res-card.highlight-card .res-value { color: #ffffff; text-shadow: 0 0 12px rgba(245, 158, 11, 0.4); }
.pump-res-card.highlight-card .card-accent {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px; width: 100%;
    background: linear-gradient(90deg, #f59e0b, #fbbf24, #f59e0b);
    box-shadow: 0 2px 10px rgba(245, 158, 11, 0.5);
}

/* Cavitation Custom Override */
.cav-status-card {
    align-items: center;
    text-align: center;
    grid-column: 1 / -1;
}
@media (min-width: 1440px) { .cav-status-card { grid-column: span 2; } }

.cav-status-card.status-ok {
    background: linear-gradient(135deg, rgba(2, 32, 5, 0.8), rgba(3, 26, 3, 0.9));
    border: 1px solid rgba(34, 197, 94, 0.5);
    box-shadow: 0 8px 32px rgba(34, 197, 94, 0.15);
}
.cav-status-card.status-ok .res-value { color: #4ade80; font-size: 1.8rem; text-shadow: 0 0 12px rgba(34, 197, 94, 0.4); }
.cav-status-card.status-ok .card-accent { background: linear-gradient(90deg, #22c55e, #4ade80, #22c55e); height: 4px; }

.cav-status-card.status-fail {
    background: linear-gradient(135deg, rgba(31, 3, 3, 0.8), rgba(42, 5, 5, 0.9));
    border: 1px solid rgba(239, 68, 68, 0.6);
    animation: dangerPulse 2s infinite;
}
.cav-status-card.status-fail .res-value { color: #f87171; font-size: 1.8rem; text-shadow: 0 0 15px rgba(239, 68, 68, 0.6); }
.cav-status-card.status-fail .card-accent { background: linear-gradient(90deg, #ef4444, #f87171, #ef4444); height: 4px; }

@keyframes dangerPulse { 
    0%, 100% { box-shadow: 0 0 20px rgba(239, 68, 68, 0.2); } 
    50% { box-shadow: 0 0 40px rgba(239, 68, 68, 0.4); border-color: #ef4444; } 
}

.eff-table td, .eff-table th { font-family: var(--font-mono); padding: 8px; }
input[type=number]::-webkit-inner-spin-button, 
input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }

</style>
  
/* =========================================================
   PUMP SIZING TRUE 2-COLUMN LAYOUT & SMART TABLES (PREMIUM)
========================================================= */
.pump-layout-grid {
    display: grid;
    grid-template-columns: 480px 1fr;
    gap: 24px;
    width: 100%;
    margin: 0 auto;
}
@media (min-width: 1440px) { .pump-layout-grid { grid-template-columns: 500px 1fr; } }
@media (max-width: 1023px) { .pump-layout-grid { grid-template-columns: 1fr; } }

.sizing-panel.pump-left-panel {
    height: 100vh;
    overflow-y: auto;
    border-right: 1px solid rgba(245, 158, 11, 0.2);
    background: linear-gradient(180deg, #050d05 0%, #030803 100%);
    position: relative;
    padding-right: 12px;
}
.sizing-panel.pump-left-panel::-webkit-scrollbar { width: 6px; }
.sizing-panel.pump-left-panel::-webkit-scrollbar-track { background: #050d05; }
.sizing-panel.pump-left-panel::-webkit-scrollbar-thumb { background: rgba(245, 158, 11, 0.4); border-radius: 3px; }

/* Zone A: Badge Bar */
.pump-badge-bar {
    width: 100%;
    height: auto;
    min-height: 56px;
    background: rgba(10, 26, 10, 0.6);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(245, 158, 11, 0.3);
    display: flex;
    align-items: center;
    justify-content: space-around;
    padding: 10px 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
}
.pump-badge-bar .top-pill {
    background: rgba(13, 31, 13, 0.8);
    border: 1px solid rgba(245,158,11,0.5);
    border-radius: 20px;
    padding: 6px 16px;
    display: flex;
    align-items: baseline;
    gap: 8px;
    box-shadow: 0 0 12px rgba(245,158,11,0.15);
    transition: all 0.3s ease;
}
.pump-badge-bar .top-pill:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(245,158,11,0.3);
    border-color: #f59e0b;
}
.pump-badge-bar .lbl { font-family: var(--font-mono); font-size: 0.85rem; font-variant: small-caps; color: #4ade80; opacity: 0.9; }
.pump-badge-bar .val { font-family: var(--font-mono); font-size: 1.1rem; font-weight: 700; color: #ffffff; text-shadow: 0 0 8px rgba(255,255,255,0.3); }
.pump-badge-bar .unt { font-family: var(--font-mono); font-size: 0.75rem; color: rgba(255,255,255,0.5); }

/* Zone B: Output Cards Grid */
.pump-results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    padding: 0 16px 24px 16px;
    width: 100%;
}
@media (min-width: 1440px) { .pump-results-grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 1023px) { .pump-results-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 599px) { .pump-results-grid { grid-template-columns: 1fr; } }

.pump-res-card {
    background: rgba(13, 31, 13, 0.4);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(74, 222, 128, 0.1);
    border-radius: 12px;
    padding: 20px;
    min-height: 110px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.pump-res-card:hover {
    background: rgba(13, 31, 13, 0.7);
    border-color: rgba(74, 222, 128, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
}
.pump-res-card .res-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #4ade80;
    opacity: 0.8;
    margin-bottom: 12px;
}
.pump-res-card .res-value {
    font-family: var(--font-mono);
    font-size: 1.6rem;
    font-weight: 700;
    color: #f1f5f9;
    line-height: 1;
    word-break: break-all;
    white-space: pre-wrap;
}
.pump-res-card .res-unit {
    font-size: 1rem;
    font-weight: 400;
    color: rgba(255,255,255,0.4);
    margin-left: 4px;
}

/* Highlighted Cards */
.pump-res-card.highlight-card {
    background: linear-gradient(135deg, rgba(20, 30, 15, 0.8) 0%, rgba(10, 15, 5, 0.9) 100%);
    border: 1px solid rgba(245, 158, 11, 0.5);
    box-shadow: 0 8px 32px rgba(245, 158, 11, 0.15), inset 0 0 20px rgba(245, 158, 11, 0.05);
}
.pump-res-card.highlight-card:hover {
    box-shadow: 0 12px 40px rgba(245, 158, 11, 0.25), inset 0 0 30px rgba(245, 158, 11, 0.1);
    border-color: #f59e0b;
}
.pump-res-card.highlight-card .res-label { color: #fcd34d; }
.pump-res-card.highlight-card .res-value { color: #ffffff; text-shadow: 0 0 12px rgba(245, 158, 11, 0.4); }
.pump-res-card.highlight-card .card-accent {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px; width: 100%;
    background: linear-gradient(90deg, #f59e0b, #fbbf24, #f59e0b);
    box-shadow: 0 2px 10px rgba(245, 158, 11, 0.5);
}

/* Cavitation Custom Override */
.cav-status-card {
    align-items: center;
    text-align: center;
    grid-column: 1 / -1;
}
@media (min-width: 1440px) { .cav-status-card { grid-column: span 2; } }

.cav-status-card.status-ok {
    background: linear-gradient(135deg, rgba(2, 32, 5, 0.8), rgba(3, 26, 3, 0.9));
    border: 1px solid rgba(34, 197, 94, 0.5);
    box-shadow: 0 8px 32px rgba(34, 197, 94, 0.15);
}
.cav-status-card.status-ok .res-value { color: #4ade80; font-size: 1.8rem; text-shadow: 0 0 12px rgba(34, 197, 94, 0.4); }
.cav-status-card.status-ok .card-accent { background: linear-gradient(90deg, #22c55e, #4ade80, #22c55e); height: 4px; }

.cav-status-card.status-fail {
    background: linear-gradient(135deg, rgba(31, 3, 3, 0.8), rgba(42, 5, 5, 0.9));
    border: 1px solid rgba(239, 68, 68, 0.6);
    animation: dangerPulse 2s infinite;
}
.cav-status-card.status-fail .res-value { color: #f87171; font-size: 1.8rem; text-shadow: 0 0 15px rgba(239, 68, 68, 0.6); }
.cav-status-card.status-fail .card-accent { background: linear-gradient(90deg, #ef4444, #f87171, #ef4444); height: 4px; }

@keyframes dangerPulse { 
    0%, 100% { box-shadow: 0 0 20px rgba(239, 68, 68, 0.2); } 
    50% { box-shadow: 0 0 40px rgba(239, 68, 68, 0.4); border-color: #ef4444; } 
}

.eff-table td, .eff-table th { font-family: var(--font-mono); padding: 8px; }
input[type=number]::-webkit-inner-spin-button, 
input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }

</style>
</head>
<body>
  <!-- Top Indian Tricolor Stripe -->
  <div class="tricolor-stripe">
    <div class="stripe-saffron"></div>
    <div class="stripe-white"></div>
    <div class="stripe-green"></div>
  </div>

  <div class="terminal-container">
    <!-- Top Header Bar -->
    <header class="terminal-header">
      <div class="header-logo">
        <!-- High-fidelity Ashoka Chakra SVG -->
        <svg class="logo-icon" viewBox="0 0 24 24" width="22" height="22">
          <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="0.8" />
          <circle cx="12" cy="12" r="2" fill="none" stroke="currentColor" stroke-width="0.8" />
          <!-- 24 Spokes -->
          <line x1="12" y1="2" x2="12" y2="22" stroke="currentColor" stroke-width="0.4" />
          <line x1="12" y1="2" x2="12" y2="22" stroke="currentColor" stroke-width="0.4" transform="rotate(15 12 12)" />
          <line x1="12" y1="2" x2="12" y2="22" stroke="currentColor" stroke-width="0.4" transform="rotate(30 12 12)" />
          <line x1="12" y1="2" x2="12" y2="22" stroke="currentColor" stroke-width="0.4" transform="rotate(45 12 12)" />
          <line x1="12" y1="2" x2="12" y2="22" stroke="currentColor" stroke-width="0.4" transform="rotate(60 12 12)" />
          <line x1="12" y1="2" x2="12" y2="22" stroke="currentColor" stroke-width="0.4" transform="rotate(75 12 12)" />
          <line x1="12" y1="2" x2="12" y2="22" stroke="currentColor" stroke-width="0.4" transform="rotate(90 12 12)" />
          <line x1="12" y1="2" x2="12" y2="22" stroke="currentColor" stroke-width="0.4" transform="rotate(105 12 12)" />
          <line x1="12" y1="2" x2="12" y2="22" stroke="currentColor" stroke-width="0.4" transform="rotate(120 12 12)" />
          <line x1="12" y1="2" x2="12" y2="22" stroke="currentColor" stroke-width="0.4" transform="rotate(135 12 12)" />
          <line x1="12" y1="2" x2="12" y2="22" stroke="currentColor" stroke-width="0.4" transform="rotate(150 12 12)" />
          <line x1="12" y1="2" x2="12" y2="22" stroke="currentColor" stroke-width="0.4" transform="rotate(165 12 12)" />
        </svg>
        <span class="logo-text">BHARAT FLOWSIZE<span class="logo-accent">DIGITAL SUITE</span></span>
      </div>
      <div class="header-status">
        <div class="status-indicator">
          <span class="pulse-dot"></span>
          <span class="status-label">DIGITAL_INDIA_ENGINE_ACTIVE</span>
        </div>
        <div class="header-divider"></div>
        <button id="btn-theme-toggle" class="theme-toggle-btn" title="Toggle Theme" aria-label="Toggle Light/Dark Theme">
          <svg class="sun-icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="moon-icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <div class="header-divider"></div>
        <div id="unit-selector-container" class="unit-selector-container" style="display: flex; align-items: center; margin-right: 10px;">
          <select id="global-unit-system" class="form-control" style="font-family: var(--font-mono); font-size: 11px; padding: 2px 6px; background: var(--bg-input); border: 1px solid var(--border-muted); color: var(--text-header); height: 26px; border-radius: var(--radius-sm);">
            <option value="SI" selected>SI Units</option>
            <option value="US">US Customary</option>
            <option value="CGS">Mixed / CGS</option>
          </select>
        </div>
        <div class="header-divider"></div>
        <div id="current-time" class="header-time">00:00:00</div>
      </div>
    </header>

    <!-- Tab Control Navigation -->
    <nav class="terminal-nav">
      <button class="nav-tab active" data-tab="pump-tab">
        <span class="tab-num">01.</span> PUMP SIZING
      </button>
      <button class="nav-tab" data-tab="line-tab">
        <span class="tab-num">02.</span> LINE SIZING
      </button>
      <button class="nav-tab" data-tab="report-tab">
        <span class="tab-num">03.</span> SUMMARY REPORT
      </button>
      <button class="nav-tab" data-tab="sthe-tab">
        <span class="tab-num">04.</span> STHE DESIGN
      </button>
    </nav>

    <main class="terminal-main">
      <!-- TAB 1: PUMP SIZING -->
      <section id="pump-tab" class="tab-content active">
        <div class="pump-layout-grid">
          <!-- Left Column: Inputs -->
          
          <div class="panel panel-input pump-input-panel sizing-panel pump-left-panel" style="max-height: 100vh; height: 100vh; overflow-y: auto; overflow-x: hidden; position: relative;">
            
            <!-- BACKGROUND SVG SCHEMATIC -->
            <svg class="pump-bg-schematic" viewBox="0 0 400 800" preserveAspectRatio="xMidYMid slice" aria-hidden="true" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.08; pointer-events: none;">
                <!-- Suction Vessel -->
                <rect x="50" y="100" width="80" height="150" rx="10" fill="none" stroke="#1a2a1a" stroke-width="4"/>
                <path d="M50 120 Q90 90 130 120" fill="none" stroke="#1a2a1a" stroke-width="4"/>
                <path d="M50 230 Q90 260 130 230" fill="none" stroke="#1a2a1a" stroke-width="4"/>
                
                <!-- Suction Pipe -->
                <path d="M130 200 L200 200 L200 380 L250 380" fill="none" stroke="#1a2a1a" stroke-width="8"/>
                
                <!-- Animated Arrows Suction -->
                <g class="flow-arrows" style="animation: flowMove 4s linear infinite; opacity: 0.12;" stroke="#00b875" stroke-width="4" fill="none">
                    <path d="M140 190 L150 200 L140 210" />
                    <path d="M160 190 L170 200 L160 210" />
                    <path d="M190 220 L200 230 L210 220" />
                    <path d="M190 250 L200 260 L210 250" />
                </g>

                <!-- Centrifugal Pump -->
                <circle cx="280" cy="380" r="30" fill="none" stroke="#1a2a1a" stroke-width="6"/>
                <path d="M250 380 L310 380 M280 350 L280 410" stroke="#1a2a1a" stroke-width="2"/>
                <polygon points="280,360 295,390 265,390" fill="none" stroke="#1a2a1a" stroke-width="2"/>

                <!-- Discharge Pipe -->
                <path d="M280 350 L280 150 L340 150" fill="none" stroke="#1a2a1a" stroke-width="8"/>
                
                <!-- Animated Arrows Discharge -->
                <g class="flow-arrows-up" style="animation: flowMoveUp 4s linear infinite; opacity: 0.12;" stroke="#00b875" stroke-width="4" fill="none">
                    <path d="M270 320 L280 310 L290 320" />
                    <path d="M270 280 L280 270 L290 280" />
                    <path d="M310 140 L320 150 L310 160" />
                </g>
                
                <!-- Destination Vessel -->
                <rect x="340" y="80" width="50" height="100" rx="5" fill="none" stroke="#1a2a1a" stroke-width="4"/>
                
            </svg>

            <div class="panel-header pump-sticky-header" style="position: sticky; top: 0; z-index: 10; background: var(--bg-app); border-bottom: 1px solid var(--color-saffron); padding: 12px; display: flex; align-items: center; gap: 8px;">
              <div style="width: 8px; height: 8px; background: var(--color-green); border-radius: 50%; box-shadow: 0 0 8px var(--color-green); animation: pulseGreen 2s infinite;"></div>
              <span style="font-family: var(--font-mono); color: var(--color-saffron); font-weight: 700; font-size: 1.1rem; letter-spacing: 0.05em;">⚙ PUMP HYDRAULICS — DESIGN CONSOLE</span>
            </div>
            
            <div class="panel-body" style="position: relative; z-index: 1; padding: 16px;">
              <form id="pump-form" class="pump-accordion-form">
              
                <!-- 01 IDENTIFICATION -->
                <details class="pump-accordion" open>
                    <summary>01 &middot; IDENTIFICATION <span class="chevron">&#9660;</span></summary>
                    <div class="acc-content input-grid-3">
                        <div class="input-cell pump-cell">
                          <label for="pump-tag">Pump Tag No</label>
                          <input type="text" id="pump-tag" class="form-control text-data pump-input" value="ABC" required>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-operating-count">No. of Operating Pumps</label>
                          <input type="number" id="pump-operating-count" class="form-control text-data pump-input" value="1" min="1" step="1" required>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-location">Pump Location</label>
                          <input type="text" id="pump-location" class="form-control text-data pump-input" value="FCCU UNIT" required>
                        </div>
                    </div>
                </details>

                <!-- 02 FLUID PROPERTIES -->
                <details class="pump-accordion" open>
                    <summary>02 &middot; FLUID PROPERTIES <span class="chevron">&#9660;</span></summary>
                    <div class="acc-content input-grid-3">
                        <div class="input-cell pump-cell" style="grid-column: span 3;">
                          <label for="pump-fluid">Service Fluid</label>
                          <div class="select-wrapper">
                            <select id="pump-fluid" class="form-control pump-input">
                              <option value="water">Water</option>
                              <option value="steam">Steam</option>
                              <option value="light_hydrocarbon">Light Hydrocarbon</option>
                              <option value="heavy_hydrocarbon">Heavy Hydrocarbon</option>
                              <option value="ammonia">Ammonia</option>
                              <option value="methanol">Methanol</option>
                              <option value="custom">Custom Fluid</option>
                            </select>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-density">Density</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="density" id="pump-density" class="form-control text-data pump-input" value="997" step="any" required>
                            <span class="unit" data-unit-type="density">kg/m³</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-vapor-pres">Vapor Pressure</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="pressure" id="pump-vapor-pres" class="form-control text-data pump-input" value="0.032" step="any" required>
                            <span class="unit" data-unit-type="pressure">bar A</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-viscosity">Viscosity</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="viscosity" id="pump-viscosity" class="form-control text-data pump-input" value="0.89" step="any" required>
                            <span class="unit" data-unit-type="viscosity">cP</span>
                          </div>
                        </div>
                    </div>
                </details>

                <!-- 03 TEMPERATURE DATA -->
                <details class="pump-accordion" open>
                    <summary>03 &middot; TEMPERATURE DATA <span class="chevron">&#9660;</span></summary>
                    <div class="acc-content input-grid-3">
                        <div class="input-cell pump-cell">
                          <label for="pump-temp-min">Min Temp</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="temperature" id="pump-temp-min" class="form-control text-data pump-input" value="15" step="any">
                            <span class="unit" data-unit-type="temperature">°C</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-temp-norm">Normal Temp</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="temperature" id="pump-temp-norm" class="form-control text-data pump-input" value="25" step="any">
                            <span class="unit" data-unit-type="temperature">°C</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-temp-max">Max Temp</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="temperature" id="pump-temp-max" class="form-control text-data pump-input" value="45" step="any">
                            <span class="unit" data-unit-type="temperature">°C</span>
                          </div>
                        </div>
                    </div>
                </details>

                <!-- 04 PROCESS SIZING FLOWRATES -->
                <details class="pump-accordion" open>
                    <summary>04 &middot; PROCESS SIZING FLOWRATES <span class="chevron">&#9660;</span></summary>
                    <div class="acc-content input-grid-3">
                        <div class="input-cell pump-cell">
                          <label for="pump-mass-flow">Normal Mass Flow <span class="micro-badge" id="badge-mass-flow"></span></label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="mass-flow" id="pump-mass-flow" class="form-control text-data pump-input" value="99700" step="any">
                            <span class="unit" data-unit-type="mass-flow">kg/hr</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-vol-flow">Normal Vol Flow <span class="micro-badge" id="badge-vol-flow"></span></label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="vol-flow" id="pump-vol-flow" class="form-control text-data pump-input" value="100" step="any">
                            <span class="unit" data-unit-type="vol-flow">m³/hr</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-margin">Design Flow Margin</label>
                          <div class="input-with-unit">
                            <input type="number" id="pump-margin" class="form-control text-data pump-input" value="0" step="any">
                            <span class="unit">%</span>
                          </div>
                        </div>
                    </div>
                </details>

                <!-- 05 SUCTION LINE & ELEVATION LAYOUT -->
                <details class="pump-accordion" open>
                    <summary>05 &middot; SUCTION LINE & ELEVATION LAYOUT <span class="chevron">&#9660;</span></summary>
                    <div class="acc-content input-grid-3">
                        <div class="input-cell pump-cell">
                          <label for="pump-suc-pressure">Suction Op Press <span class="micro-badge" id="badge-suc-press"></span></label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="pressure" id="pump-suc-pressure" class="form-control text-data pump-input" value="3.0" step="any">
                            <span class="unit" data-unit-type="pressure">bar G</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-atm-pressure">Atm Pressure</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="pressure" id="pump-atm-pressure" class="form-control text-data pump-input" value="1.01325" step="any">
                            <span class="unit" data-unit-type="pressure">bar A</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-suc-dp">Suction Line Drop (ΔP)</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="press-drop" id="pump-suc-dp" class="form-control text-data pump-input" value="0.01" step="any">
                            <span class="unit" data-unit-type="press-drop">bar</span>
                          </div>
                        </div>
                        
                        <div class="input-cell pump-cell">
                          <label for="pump-vessel-el">Vessel Elevation <span class="micro-badge" id="badge-static-head"></span></label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="length-m" id="pump-vessel-el" class="form-control text-data pump-input" value="4.0" step="any">
                            <span class="unit" data-unit-type="length-m">m</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-lll">LLL Elevation</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="length-m" id="pump-lll" class="form-control text-data pump-input" value="0.0" step="any">
                            <span class="unit" data-unit-type="length-m">m</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-centreline-el">Pump Centreline El</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="length-m" id="pump-centreline-el" class="form-control text-data pump-input" value="0.75" step="any">
                            <span class="unit" data-unit-type="length-m">m</span>
                          </div>
                        </div>
                    </div>
                </details>

                <!-- LIVE MINI GAUGES (Between 05 and 06) -->
                <div class="mini-gauges-strip" style="display: flex; justify-content: space-around; background: #050d05; border: 1px solid #1a3a1a; border-radius: 8px; padding: 12px; margin: 12px 0;">
                    <div class="mini-gauge-container">
                        <div class="mini-gauge-title">NPSH STATUS</div>
                        <svg class="mini-gauge-svg" width="80" height="40" viewBox="0 0 100 50">
                            <path d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#1a3a1a" stroke-width="12" stroke-linecap="round"/>
                            <path id="gauge-arc-npsh" d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="var(--color-green)" stroke-width="12" stroke-dasharray="125" stroke-dashoffset="125" stroke-linecap="round" style="transition: stroke-dashoffset 0.5s;"/>
                            <text id="gauge-val-npsh" x="50" y="45" text-anchor="middle" font-family="var(--font-mono)" font-size="16" fill="white" font-weight="bold">0</text>
                        </svg>
                    </div>
                    <div class="mini-gauge-container">
                        <div class="mini-gauge-title">VELOCITY</div>
                        <svg class="mini-gauge-svg" width="80" height="40" viewBox="0 0 100 50">
                            <path d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#1a3a1a" stroke-width="12" stroke-linecap="round"/>
                            <path id="gauge-arc-vel" d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="var(--color-saffron)" stroke-width="12" stroke-dasharray="125" stroke-dashoffset="125" stroke-linecap="round" style="transition: stroke-dashoffset 0.5s;"/>
                            <text id="gauge-val-vel" x="50" y="45" text-anchor="middle" font-family="var(--font-mono)" font-size="16" fill="white" font-weight="bold">0</text>
                        </svg>
                    </div>
                    <div class="mini-gauge-container">
                        <div class="mini-gauge-title">MOTOR LOAD</div>
                        <svg class="mini-gauge-svg" width="80" height="40" viewBox="0 0 100 50">
                            <path d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#1a3a1a" stroke-width="12" stroke-linecap="round"/>
                            <path id="gauge-arc-motor" d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="#3b82f6" stroke-width="12" stroke-dasharray="125" stroke-dashoffset="125" stroke-linecap="round" style="transition: stroke-dashoffset 0.5s;"/>
                            <text id="gauge-val-motor" x="50" y="45" text-anchor="middle" font-family="var(--font-mono)" font-size="16" fill="white" font-weight="bold">0%</text>
                        </svg>
                    </div>
                </div>

                <!-- 06 DISCHARGE SIDE -->
                <details class="pump-accordion" open>
                    <summary>06 &middot; DISCHARGE SIDE <span class="chevron">&#9660;</span></summary>
                    <div class="acc-content input-grid-3">
                        <div class="input-cell pump-cell">
                          <label for="pump-dest-a">Dest Equip Press (A)</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="pressure" id="pump-dest-a" class="form-control text-data pump-input" value="3.0" step="any" required>
                            <span class="unit" data-unit-type="pressure">bar G</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-dest-b">Dest Equip Press (B)</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="pressure" id="pump-dest-b" class="form-control text-data pump-input" value="3.0" step="any" required>
                            <span class="unit" data-unit-type="pressure">bar G</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-dest-c">Dest Equip Press (C)</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="pressure" id="pump-dest-c" class="form-control text-data pump-input" value="3.0" step="any" required>
                            <span class="unit" data-unit-type="pressure">bar G</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-discharge-el">Discharge Elevation</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="length-m" id="pump-discharge-el" class="form-control text-data pump-input" value="10.0" step="any" required>
                            <span class="unit" data-unit-type="length-m">m</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-disch-dp">Discharge Drop (ΔP)</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="press-drop" id="pump-disch-dp" class="form-control text-data pump-input" value="0.5" step="any" required>
                            <span class="unit" data-unit-type="press-drop">bar</span>
                          </div>
                        </div>
                        <div class="input-cell pump-cell">
                          <label for="pump-diff-head">Locked Diff Head</label>
                          <div class="input-with-unit">
                            <input type="number" data-unit-type="length-m" id="pump-diff-head" class="form-control text-data pump-input" value="0.0" step="any" readonly disabled>
                            <span class="unit" data-unit-type="length-m">m</span>
                          </div>
                        </div>
                    </div>
                </details>

                
                <!-- 07 POWER CALCULATIONS CONFIGURATION -->
                <details class="pump-accordion" open>
                    <summary>07 &middot; POWER CALCULATIONS CONFIGURATION <span class="chevron">&#9660;</span></summary>
                    <div class="acc-content">
                        <div class="input-cell pump-cell" style="margin-bottom: 12px;">
                          <label for="pump-shutoff-margin">Shut-off Head Margin</label>
                          <div class="input-with-unit" style="max-width: 150px;">
                            <input type="number" id="pump-shutoff-margin" class="form-control text-data pump-input" value="20" step="any" required>
                            <span class="unit">%</span>
                          </div>
                        </div>

                        <div style="display: flex; gap: 12px; margin-bottom: 12px; flex-wrap: wrap;">
                            <!-- Pump Efficiency Table -->
                            <div style="flex: 1; min-width: 200px; border: 1px solid var(--border-muted); border-radius: 4px; background: #050d05; overflow: hidden; display: flex; flex-direction: column;">
                                <div style="background: #0a1a0a; border-bottom: 2px solid var(--border-muted); padding: 6px; text-align: center; color: var(--color-saffron); font-family: var(--font-mono); font-size: 10px; font-weight: bold; letter-spacing: 0.05em;">PUMP EFFICIENCY REFERENCE</div>
                                <table class="eff-table" id="table-pump-eff" style="width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 9px; color: #ffffff;">
                                    <tbody>
                                        <tr class="eff-row"><td class="eff-radio" style="padding:4px;"><input type="radio" name="peff-radio" value="0"></td><td class="eff-name" style="padding:4px;">Small Utility Pump (&lt;5 kW)</td><td class="eff-range" style="padding:4px; text-align:right;">[<input type="number" class="eff-val p-min" value="50" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">] &ndash; [<input type="number" class="eff-val p-max" value="65" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">]</td></tr>
                                        <tr class="eff-row bg-alt" style="background: #071007;"><td class="eff-radio" style="padding:4px;"><input type="radio" name="peff-radio" value="1"></td><td class="eff-name" style="padding:4px;">5&ndash;20 kW</td><td class="eff-range" style="padding:4px; text-align:right;">[<input type="number" class="eff-val p-min" value="60" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">] &ndash; [<input type="number" class="eff-val p-max" value="75" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">]</td></tr>
                                        <tr class="eff-row active-eff-row" style="background: #0a2a0a; border-left: 3px solid #f59e0b;"><td class="eff-radio" style="padding:4px;"><input type="radio" name="peff-radio" value="2" checked></td><td class="eff-name" style="padding:4px; color:#f59e0b;">20&ndash;100 kW</td><td class="eff-range" style="padding:4px; text-align:right;">[<input type="number" class="eff-val p-min" value="70" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">] &ndash; [<input type="number" class="eff-val p-max" value="85" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">]</td></tr>
                                        <tr class="eff-row bg-alt" style="background: #071007;"><td class="eff-radio" style="padding:4px;"><input type="radio" name="peff-radio" value="3"></td><td class="eff-name" style="padding:4px;">&gt;100 kW</td><td class="eff-range" style="padding:4px; text-align:right;">[<input type="number" class="eff-val p-min" value="75" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">] &ndash; [<input type="number" class="eff-val p-max" value="90" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">]</td></tr>
                                        <tr class="eff-row"><td class="eff-radio" style="padding:4px;"><input type="radio" name="peff-radio" value="4"></td><td class="eff-name" style="padding:4px;">Centrifugal Process (API)</td><td class="eff-range" style="padding:4px; text-align:right;">[<input type="number" class="eff-val p-min" value="75" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">] &ndash; [<input type="number" class="eff-val p-max" value="85" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">]</td></tr>
                                        <tr class="eff-row bg-alt" style="background: #071007;"><td class="eff-radio" style="padding:4px;"><input type="radio" name="peff-radio" value="5"></td><td class="eff-name" style="padding:4px;">Multistage Pump</td><td class="eff-range" style="padding:4px; text-align:right;">[<input type="number" class="eff-val p-min" value="75" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">] &ndash; [<input type="number" class="eff-val p-max" value="88" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">]</td></tr>
                                    </tbody>
                                </table>
                                <div style="padding: 6px; background: #071007; border-top: 1px solid var(--border-muted); margin-top: auto; display: flex; justify-content: space-between; align-items: center;">
                                    <div style="font-family: var(--font-mono); font-size: 9px; color: var(--color-green);">Override: [<input type="number" id="pump-eff-override" style="width: 40px; background: #0a1a0a; border: 1px solid #1a3a1a; color: #fff; text-align: center;">] %</div>
                                    <div style="font-family: var(--font-mono); font-size: 10px; color: var(--color-saffron); font-weight: bold;">Active: <span id="active-pump-eff-disp">77.5</span>%</div>
                                </div>
                            </div>

                            <!-- Motor Efficiency Table -->
                            <div style="flex: 1; min-width: 200px; border: 1px solid var(--border-muted); border-radius: 4px; background: #050d05; overflow: hidden; display: flex; flex-direction: column;">
                                <div style="background: #0a1a0a; border-bottom: 2px solid var(--border-muted); padding: 6px; text-align: center; color: var(--color-saffron); font-family: var(--font-mono); font-size: 10px; font-weight: bold; letter-spacing: 0.05em;">MOTOR EFFICIENCY REFERENCE</div>
                                <table class="eff-table" id="table-motor-eff" style="width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 9px; color: #ffffff;">
                                    <tbody>
                                        <tr class="eff-row"><td class="eff-radio" style="padding:4px;"><input type="radio" name="meff-radio" value="0"></td><td class="eff-name" style="padding:4px;">&lt;5 kW</td><td class="eff-range" style="padding:4px; text-align:right;">[<input type="number" class="eff-val m-min" value="80" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">] &ndash; [<input type="number" class="eff-val m-max" value="88" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">]</td></tr>
                                        <tr class="eff-row bg-alt" style="background: #071007;"><td class="eff-radio" style="padding:4px;"><input type="radio" name="meff-radio" value="1"></td><td class="eff-name" style="padding:4px;">5&ndash;20 kW</td><td class="eff-range" style="padding:4px; text-align:right;">[<input type="number" class="eff-val m-min" value="88" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">] &ndash; [<input type="number" class="eff-val m-max" value="92" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">]</td></tr>
                                        <tr class="eff-row active-eff-row" style="background: #0a2a0a; border-left: 3px solid #f59e0b;"><td class="eff-radio" style="padding:4px;"><input type="radio" name="meff-radio" value="2" checked></td><td class="eff-name" style="padding:4px; color:#f59e0b;">20&ndash;50 kW</td><td class="eff-range" style="padding:4px; text-align:right;">[<input type="number" class="eff-val m-min" value="92" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">] &ndash; [<input type="number" class="eff-val m-max" value="94" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">]</td></tr>
                                        <tr class="eff-row bg-alt" style="background: #071007;"><td class="eff-radio" style="padding:4px;"><input type="radio" name="meff-radio" value="3"></td><td class="eff-name" style="padding:4px;">50&ndash;200 kW</td><td class="eff-range" style="padding:4px; text-align:right;">[<input type="number" class="eff-val m-min" value="94" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">] &ndash; [<input type="number" class="eff-val m-max" value="96" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">]</td></tr>
                                        <tr class="eff-row"><td class="eff-radio" style="padding:4px;"><input type="radio" name="meff-radio" value="4"></td><td class="eff-name" style="padding:4px;">Premium IE3/IE4</td><td class="eff-range" style="padding:4px; text-align:right;">[<input type="number" class="eff-val m-min" value="95" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">] &ndash; [<input type="number" class="eff-val m-max" value="97" style="width:30px;background:transparent;border:none;color:#fff;text-align:center;">]</td></tr>
                                    </tbody>
                                </table>
                                <div style="padding: 6px; background: #071007; border-top: 1px solid var(--border-muted); margin-top: auto; display: flex; justify-content: space-between; align-items: center;">
                                    <div style="font-family: var(--font-mono); font-size: 9px; color: var(--color-green);">Override: [<input type="number" id="motor-eff-override" style="width: 40px; background: #0a1a0a; border: 1px solid #1a3a1a; color: #fff; text-align: center;">] %</div>
                                    <div style="font-family: var(--font-mono); font-size: 10px; color: var(--color-saffron); font-weight: bold;">Active: <span id="active-motor-eff-disp">93.0</span>%</div>
                                </div>
                            </div>
                        </div>

                        <div class="input-cell pump-cell" style="margin-top: 12px;">
                          <label for="pump-motor-sf">Motor Service Factor</label>
                          <div class="input-with-unit" style="max-width: 150px;">
                            <input type="number" id="pump-motor-sf" class="form-control text-data pump-input" value="20" step="any" required>
                            <span class="unit">%</span>
                          </div>
                        </div>
                    </div>
                </details>


                <!-- 08 NPSH MARGIN REFERENCE TABLE -->
                <details class="pump-accordion" open>
                    <summary>08 &middot; NPSH MARGIN REFERENCE TABLE <span class="chevron">&#9660;</span></summary>
                    <div class="acc-content">
                        <input type="hidden" id="pump-npshr" data-unit-type="length-m" value="1.0">
                        <div class="table-responsive" style="border: 1px solid var(--border-muted); border-radius: var(--radius-sm); overflow: hidden; background: var(--bg-input);">
                        <table class="report-table" style="width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 10px; color: var(--text-main);">
                          <thead>
                            <tr style="border-bottom: 2px solid var(--border-muted); background: rgba(255,255,255,0.02); text-align: left;">
                              <th style="padding: 4px 6px; font-weight: 600; color: var(--text-header); width: 40px; text-align: center; border-right: 1px solid var(--border-muted);">ACT</th>
                              <th style="padding: 4px 6px; font-weight: 600; color: var(--text-header); border-right: 1px solid var(--border-muted);">SERVICE TYPE</th>
                              <th style="padding: 4px 6px; font-weight: 600; color: var(--text-header); text-align: right; width: 120px;">MARGIN (<span class="unit-npsh-margin-table" data-unit-type="length-m">m</span>)</th>
                            </tr>
                          </thead>
                          <tbody>
                            <tr style="border-bottom: 1px solid var(--border-muted);">
                              <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);">
                                <input type="radio" name="npsh-active-row" value="water" checked style="cursor: pointer; accent-color: var(--color-saffron);">
                              </td>
                              <td style="padding: 4px; border-right: 1px solid var(--border-muted);">
                                <input type="text" id="npsh-lbl-water" class="form-control table-input pump-input" value="Water" style="background: transparent; border: none; color: var(--text-header); width: 100%; font-family: var(--font-mono); font-size: 10px; padding: 2px;">
                              </td>
                              <td style="padding: 4px; text-align: right;">
                                <input type="number" id="npsh-val-water" data-unit-type="length-m" class="form-control table-input pump-input" value="1.0" step="any" style="background: transparent; border: none; color: var(--text-header); width: 100%; font-family: var(--font-mono); font-size: 10px; text-align: right; padding: 2px;">
                              </td>
                            </tr>
                            <tr style="border-bottom: 1px solid var(--border-muted);">
                              <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);">
                                <input type="radio" name="npsh-active-row" value="hydrocarbon" style="cursor: pointer; accent-color: var(--color-saffron);">
                              </td>
                              <td style="padding: 4px; border-right: 1px solid var(--border-muted);">
                                <input type="text" id="npsh-lbl-hydrocarbon" class="form-control table-input pump-input" value="Hydrocarbon" style="background: transparent; border: none; color: var(--text-header); width: 100%; font-family: var(--font-mono); font-size: 10px; padding: 2px;">
                              </td>
                              <td style="padding: 4px; text-align: right;">
                                <input type="number" id="npsh-val-hydrocarbon" data-unit-type="length-m" class="form-control table-input pump-input" value="1.5" step="any" style="background: transparent; border: none; color: var(--text-header); width: 100%; font-family: var(--font-mono); font-size: 10px; text-align: right; padding: 2px;">
                              </td>
                            </tr>
                            <tr style="border-bottom: 1px solid var(--border-muted);">
                              <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);">
                                <input type="radio" name="npsh-active-row" value="critical" style="cursor: pointer; accent-color: var(--color-saffron);">
                              </td>
                              <td style="padding: 4px; border-right: 1px solid var(--border-muted);">
                                <input type="text" id="npsh-lbl-critical" class="form-control table-input pump-input" value="Critical Service" style="background: transparent; border: none; color: var(--text-header); width: 100%; font-family: var(--font-mono); font-size: 10px; padding: 2px;">
                              </td>
                              <td style="padding: 4px; text-align: right;">
                                <input type="number" id="npsh-val-critical" data-unit-type="length-m" class="form-control table-input pump-input" value="2.5" step="any" style="background: transparent; border: none; color: var(--text-header); width: 100%; font-family: var(--font-mono); font-size: 10px; text-align: right; padding: 2px;">
                              </td>
                            </tr>
                            <tr>
                              <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);">
                                <input type="radio" name="npsh-active-row" value="user" style="cursor: pointer; accent-color: var(--color-saffron);">
                              </td>
                              <td style="padding: 4px; border-right: 1px solid var(--border-muted);">
                                <input type="text" id="npsh-lbl-user" class="form-control table-input pump-input" placeholder="User Defined" value="" style="background: transparent; border: none; color: var(--text-header); width: 100%; font-family: var(--font-mono); font-size: 10px; padding: 2px;">
                              </td>
                              <td style="padding: 4px; text-align: right;">
                                <input type="number" id="npsh-val-user" data-unit-type="length-m" class="form-control table-input pump-input" placeholder="0.0" value="" style="background: transparent; border: none; color: var(--text-header); width: 100%; font-family: var(--font-mono); font-size: 10px; text-align: right; padding: 2px;">
                              </td>
                            </tr>
                          </tbody>
                        </table>
                        </div>
                        <div style="font-size: 9px; color: var(--text-muted); margin-top: 4px; font-family: var(--font-mono);">
                          • Water → 0.5–1 m<br>
                          • Hydrocarbon → 1–2 m<br>
                          • Critical Service → 2–3 m
                        </div>
                    </div>
                </details>


                <button type="submit" class="btn btn-primary btn-block pump-run-btn" style="margin-top: var(--space-md);">
                  <span class="btn-text">RUN PUMP CALCULATION</span>
                  <span class="btn-icon">⚡</span>
                </button>
              </form>
            </div>
          </div>


          <div class="pump-right-panel" style="width: 100%; display: flex; flex-direction: column;">


    <!-- Outputs Panel -->
    <div class="panel panel-output" style="position: relative;">
      <!-- Simulation Processing Overlay -->
      <div id="pump-sim-overlay" class="sim-overlay">
        <div class="sim-spinner"></div>
        <div class="sim-title">Evaluating Pump Sizing</div>
        <div class="sim-scanline"></div>
        <div class="sim-console-text">Solving static pressure heads...</div>
      </div>

      
      
            <div class="panel-body">
        <div id="pump-results" class="results-container">
          <!-- Sizing Status Banner -->
          <div class="status-banner banner-teal" style="margin-bottom: var(--space-md); padding: 8px 12px; border: 1px solid var(--border-muted); border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 10px; display: flex; justify-content: space-between; align-items: center;">
            <span class="banner-message">READY // BHARAT FLOWSIZE ACTIVE</span>
          </div>
          <div class="results-layout-wrapper">
            <!-- Left Column: Visualizations & Audits -->
            <div class="results-column-visual">
              <!-- 3D centifugal Pump WebGL canvas container -->
              <div class="iso-animation-wrapper" style="margin-top: 0;">
                <div class="chart-title" style="display: flex; justify-content: space-between; align-items: center;">
                  <span>3D PHYSICAL LOOP SIMULATION — CENTRIFUGAL PUMP</span>
                  <button type="button" id="btn-anim-pause-pump" class="sthe-collapse-btn" style="padding: 1px 6px; font-size: 9px; line-height: 1;">PAUSE</button>
                </div>
                <div id="pump-3d-container" class="iso-animation-container" style="position: relative;">
                  <canvas id="pump-canvas" width="520" height="300" style="width:100%;max-width:520px;height:300px;display:block;background:#050810;border-radius:8px;"></canvas>
                </div>
              </div>
              <!-- Cavitation Check Visual Display -->
              <div class="rec-panel" style="margin-top: var(--space-md);">
                <div class="rec-title">NPSH CAVITATION MARGIN COMPLIANCE</div>
                <div class="dial-container" style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100px; position: relative;">
                  <!-- NPSH Margin Gauge Bar -->
                  <div class="gauge-axis" style="width: 100%; height: 6px; background: var(--bg-input); border: 1px solid var(--border-muted); border-radius: var(--radius-sm); position: relative; margin-top: 20px;">
                    <div id="gauge-bar" style="position: absolute; left: 0; top: 0; height: 100%; width: 0%; background: var(--color-green); transition: width var(--transition-normal); border-radius: var(--radius-sm);"></div>
                    <div id="gauge-marker-npshr" style="position: absolute; width: 2px; height: 16px; background: #ef4444; top: -5px; left: 30%;" title="NPSHr Limit"></div>
                    <div id="gauge-marker-margin" style="position: absolute; width: 8px; height: 8px; border-radius: 50%; background: var(--color-white); border: 2px solid var(--color-chakra); top: -3px; left: 0%; transition: left var(--transition-normal);" title="Operating Point"></div>
                  </div>
                  <div class="gauge-labels" style="display: flex; justify-content: space-between; width: 100%; margin-top: 8px; font-size: 9px; font-family: var(--font-mono); color: var(--text-muted);">
                    <span>0m</span>
                    <span id="lbl-npshr" style="color: #ef4444;">NPSHr</span>
                    <span id="lbl-npsha" style="color: var(--color-green);">NPSHa</span>
                    <span>15m</span>
                  </div>
                </div>
              </div>
            </div>
            <!-- Right Column: Numeric Results -->
            <div class="results-column-data">
              
              
<div class="pump-results-grid">

    <!-- === GENERAL PROCESS === -->
    <div class="pump-res-card">
        <div class="res-label">Service Fluid</div>
        <div class="res-value"><span id="out-pump-fluid">-</span></div>
    </div>
    <div class="pump-res-card highlight-card">
        <div class="card-accent"></div>
        <div class="res-label">Design Vol Flow</div>
        <div class="res-value"><span id="out-pump-design-flow">-</span> <span class="res-unit">m³/hr</span></div>
    </div>
    <div class="pump-res-card">
        <div class="res-label">Upstream Pressure</div>
        <div class="res-value"><span id="out-pump-up-press">-</span> <span class="res-unit">bar A</span></div>
    </div>
    <div class="pump-res-card">
        <div class="res-label">Downstream Pressure</div>
        <div class="res-value"><span id="out-pump-down-press">-</span> <span class="res-unit">bar A</span></div>
    </div>

    <!-- === SUCTION DATA === -->
    <div class="pump-res-card">
        <div class="res-label">Net Suction Pressure</div>
        <div class="res-value"><span id="out-pump-net-suc-press">-</span> <span class="res-unit" id="out-pump-net-suc-press-unit">bar A</span></div>
    </div>
    <div class="pump-res-card">
        <div class="res-label">Static Head (LLL to CL)</div>
        <div class="res-value"><span id="out-pump-static-head-suc">-</span> <span class="res-unit">m</span></div>
    </div>
    <div class="pump-res-card">
        <div class="res-label">Head at Suction</div>
        <div class="res-value"><span id="out-pump-head-suc">-</span> <span class="res-unit">m</span></div>
    </div>
    <div class="pump-res-card highlight-card">
        <div class="card-accent"></div>
        <div class="res-label">Suction Nozzle (ID)</div>
        <div class="res-value"><span id="out-pump-suc-nozzle">-</span></div>
    </div>
    <div class="pump-res-card highlight-card">
        <div class="card-accent"></div>
        <div class="res-label">Suction Velocity</div>
        <div class="res-value"><span id="out-pump-suc-vel">-</span> <span class="res-unit">m/s</span></div>
    </div>

    <!-- === DISCHARGE DATA === -->
    <div class="pump-res-card highlight-card">
        <div class="card-accent"></div>
        <div class="res-label">Discharge Nozzle (ID)</div>
        <div class="res-value"><span id="out-pump-dis-nozzle">-</span></div>
    </div>
    <div class="pump-res-card highlight-card">
        <div class="card-accent"></div>
        <div class="res-label">Discharge Velocity</div>
        <div class="res-value"><span id="out-pump-dis-vel">-</span> <span class="res-unit">m/s</span></div>
    </div>

    <!-- === PUMP PERFORMANCE === -->
    <div class="pump-res-card highlight-card">
        <div class="card-accent"></div>
        <div class="res-label">Differential Pressure</div>
        <div class="res-value"><span id="out-pump-diff-press">-</span> <span class="res-unit" id="out-pump-diff-press-unit">bar</span></div>
    </div>
    <div class="pump-res-card highlight-card">
        <div class="card-accent"></div>
        <div class="res-label">Differential Head</div>
        <div class="res-value"><span id="out-pump-diff-head-val">-</span> <span class="res-unit" id="out-pump-diff-head-val-unit">m</span></div>
    </div>
    <div class="pump-res-card">
        <div class="res-label">Shut-off Head</div>
        <div class="res-value"><span id="out-pump-shutoff-head">-</span> <span class="res-unit" id="out-pump-shutoff-head-unit">m</span></div>
    </div>

    <!-- === NPSH & CAVITATION === -->
    <div class="pump-res-card highlight-card" id="card-npsha">
        <div class="card-accent"></div>
        <div class="res-label">NPSH Available (NPSHa)</div>
        <div class="res-value"><span id="out-pump-npsha">-</span> <span class="res-unit" id="out-pump-npsha-unit">m</span></div>
    </div>
    <div class="pump-res-card" id="card-npshr">
        <div class="res-label">NPSH Required (NPSHr)</div>
        <div class="res-value"><span id="out-pump-npshr-val">-</span> <span class="res-unit" id="out-pump-npshr-val-unit">m</span></div>
    </div>
    <div class="pump-res-card highlight-card" id="card-npsh-margin">
        <div class="card-accent"></div>
        <div class="res-label">NPSH Margin</div>
        <div class="res-value"><span id="out-pump-npsh-margin">-</span> <span class="res-unit" id="out-pump-npsh-margin-unit">m</span></div>
    </div>

    <!-- CAVITATION STATUS FULL WIDTH -->
    <div class="pump-res-card cav-status-card" id="card-cavitation" style="grid-column: 1 / -1; margin-top: 8px; margin-bottom: 8px;">
        <div class="card-accent"></div>
        <div class="res-label" style="font-size: 0.85rem; color: #fff;">Pump Cavitation Status</div>
        <div class="res-value"><span id="out-pump-cavitation-status" style="letter-spacing: 0.1em; text-transform: uppercase;">-</span></div>
    </div>

    <!-- === POWER & EFFICIENCY === -->
    <div class="pump-res-card">
        <div class="res-label">Hydraulic Power</div>
        <div class="res-value"><span id="out-pump-hyd-power">-</span> <span class="res-unit" id="out-pump-hyd-power-unit">kW</span></div>
    </div>
    <div class="pump-res-card highlight-card">
        <div class="card-accent"></div>
        <div class="res-label">Brake Power (BHP)</div>
        <div class="res-value"><span id="out-pump-bhp">-</span> <span class="res-unit" id="out-pump-bhp-unit">kW</span></div>
    </div>
    <div class="pump-res-card">
        <div class="res-label">Pump Efficiency</div>
        <div class="res-value"><span id="out-pump-eff-out">-</span> <span class="res-unit">%</span></div>
    </div>
    <div class="pump-res-card highlight-card">
        <div class="card-accent"></div>
        <div class="res-label">Rec. Motor Power</div>
        <div class="res-value"><span id="out-pump-motor-kw">-</span> <span class="res-unit" id="out-pump-motor-kw-unit">kW</span></div>
    </div>
    <div class="pump-res-card">
        <div class="res-label">Standard Motor (kW)</div>
        <div class="res-value"><span id="out-pump-std-motor-kw">-</span> <span class="res-unit">kW</span></div>
    </div>
    <div class="pump-res-card">
        <div class="res-label">Standard Motor (HP)</div>
        <div class="res-value"><span id="out-pump-std-motor-hp">-</span> <span class="res-unit">HP</span></div>
    </div>
    <div class="pump-res-card">
        <div class="res-label">Motor Service Factor</div>
        <div class="res-value"><span id="out-pump-sf-out">-</span> <span class="res-unit">%</span></div>
    </div>
    <div class="pump-res-card">
        <div class="res-label">Motor Efficiency</div>
        <div class="res-value"><span id="out-pump-meff-out">-</span> <span class="res-unit">%</span></div>
    </div>

</div> <!-- End of pump-results-grid -->

<!-- === SUMMARY RESULTS BOX === -->
<div class="pump-summary-box" style="margin: 24px 16px; padding: 24px; background: rgba(10, 26, 10, 0.4); border: 1px solid rgba(245, 158, 11, 0.4); border-radius: 12px; backdrop-filter: blur(8px);">
    <div style="font-family: var(--font-mono); font-size: 0.85rem; font-weight: 700; color: #f59e0b; margin-bottom: 16px; letter-spacing: 0.1em;">PUMP HYDRAULICS EXECUTIVE SUMMARY</div>
    
    <table style="width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 14px; color: #e2e8f0;">
        <tr style="border-bottom: 1px solid rgba(74, 222, 128, 0.1);">
            <td style="padding: 8px 0; color: #4ade80; opacity: 0.8;">Service Fluid</td>
            <td id="sum-pump-fluid" style="padding: 8px 0; font-weight: bold; text-align: right;">-</td>
        </tr>
        <tr style="border-bottom: 1px solid rgba(74, 222, 128, 0.1);">
            <td style="padding: 8px 0; color: #4ade80; opacity: 0.8;">Design Vol Flow</td>
            <td id="sum-pump-flow" style="padding: 8px 0; font-weight: bold; text-align: right;">- m³/hr</td>
        </tr>
        <tr style="border-bottom: 1px solid rgba(74, 222, 128, 0.1);">
            <td style="padding: 8px 0; color: #4ade80; opacity: 0.8;">Pump Differential Head</td>
            <td id="sum-pump-head" style="padding: 8px 0; font-weight: bold; text-align: right;">- m</td>
        </tr>
        <tr style="border-bottom: 1px solid rgba(74, 222, 128, 0.1);">
            <td style="padding: 8px 0; color: #4ade80; opacity: 0.8;">NPSH Available / Margin</td>
            <td id="sum-pump-npsh" style="padding: 8px 0; font-weight: bold; text-align: right;">- m / - m</td>
        </tr>
        <tr style="border-bottom: 1px solid rgba(74, 222, 128, 0.1);">
            <td style="padding: 8px 0; color: #4ade80; opacity: 0.8;">Cavitation Check</td>
            <td id="sum-pump-cav" style="padding: 8px 0; font-weight: bold; text-align: right; color: #f87171;">-</td>
        </tr>
        <tr style="border-bottom: 1px solid rgba(74, 222, 128, 0.1);">
            <td style="padding: 8px 0; color: #4ade80; opacity: 0.8;">Brake Power (BHP)</td>
            <td id="sum-pump-bhp" style="padding: 8px 0; font-weight: bold; text-align: right;">- kW</td>
        </tr>
        <tr>
            <td style="padding: 8px 0; color: #4ade80; opacity: 0.8;">Selected Motor</td>
            <td id="sum-pump-motor" style="padding: 8px 0; font-weight: bold; text-align: right; color: #f59e0b;">- kW</td>
        </tr>
    </table>
</div>
                </div>
            </div>

              <!-- PUMP SYSTEM CHARACTERISTIC CURVES -->
              <div id="pump-curve-block" class="rec-panel" style="margin-top: var(--space-md); border: 1px solid #1a3a1a; background: #050d05; padding: 16px; border-radius: 8px;">
                <div class="chart-header-title">PUMP SYSTEM CHARACTERISTIC CURVES</div>
                <div style="width: 100%; height: 320px; position: relative; margin-top: 12px;">
                   <canvas id="pump-curve-canvas" style="width: 100%; height: 100%;"></canvas>
                   <!-- Legend overlay -->
                   <div style="position: absolute; top: 10px; left: 10px; background: rgba(5,13,5,0.8); padding: 8px; border: 1px solid #1a3a1a; border-radius: 4px; font-family: var(--font-mono); font-size: 10px; color: var(--text-main);">
                      <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 4px;">
                         <span style="display: inline-block; width: 16px; height: 2px; background: #f59e0b;"></span> Pump Head Curve (H)
                      </div>
                      <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 4px;">
                         <span style="display: inline-block; width: 16px; height: 2px; background: #22c55e;"></span> System Head Curve (H)
                      </div>
                      <div style="display: flex; align-items: center; gap: 6px;">
                         <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #ffffff;"></span> Operating Point
                      </div>
                   </div>
                </div>
              </div>

          <!-- PUMP DESIGN ASSISTANT — AUTO CORRECTION SUGGESTIONS -->
          <div id="pump-assistant-panel" class="rec-panel" style="display: none; border-left: 4px solid var(--color-saffron); background: rgba(255, 117, 56, 0.05); margin-top: var(--space-md); padding: 12px var(--space-md); font-family: var(--font-mono); border-top: 1px solid rgba(255, 117, 56, 0.15); border-right: 1px solid rgba(255, 117, 56, 0.15); border-bottom: 1px solid rgba(255, 117, 56, 0.15); border-radius: var(--radius-sm);">
            <div style="color: var(--color-saffron); font-weight: bold; font-size: 11px; margin-bottom: 6px; display: flex; align-items: center; gap: var(--space-xs);">
              <span>⚠ PUMP DESIGN ASSISTANT — AUTO CORRECTION SUGGESTIONS</span>
            </div>
            <div id="pump-assistant-content" style="font-size: 10px; color: var(--text-main);">
              <!-- dynamic suggestions list -->
            </div>
            <div id="pump-assistant-apply-all-wrapper" style="margin-top: var(--space-sm); display: none; text-align: right;">
              <button type="button" id="btn-pump-apply-all-suggestions" class="btn" style="font-size: 9px; font-family: var(--font-mono); padding: 4px 8px; background: transparent; border: 1px solid var(--color-saffron); color: var(--color-saffron); cursor: pointer; transition: all var(--transition-fast);">APPLY ALL SUGGESTIONS ⚡</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>
</section>

      <!-- TAB 2: LINE SIZING -->
      
        <section id="line-tab" class="tab-content">
        <div class="line-type-selector" style="display: flex; gap: var(--space-xs); margin-bottom: var(--space-md); border-bottom: 1px solid var(--border-muted); padding-bottom: var(--space-sm);">
          <button type="button" class="line-type-tab active" data-line-type="liquid" style="flex: 1; padding: var(--space-sm) var(--space-md); font-family: var(--font-mono); font-size: 11px; background: var(--bg-panel); border: 1px solid var(--border-muted); color: var(--text-muted); cursor: pointer; text-transform: uppercase; transition: all var(--transition-fast);">Liquid Sizing</button>
          <button type="button" class="line-type-tab" data-line-type="gas" style="flex: 1; padding: var(--space-sm) var(--space-md); font-family: var(--font-mono); font-size: 11px; background: var(--bg-panel); border: 1px solid var(--border-muted); color: var(--text-muted); cursor: pointer; text-transform: uppercase; transition: all var(--transition-fast);">Gas Sizing</button>
          <button type="button" class="line-type-tab" data-line-type="steam" style="flex: 1; padding: var(--space-sm) var(--space-md); font-family: var(--font-mono); font-size: 11px; background: var(--bg-panel); border: 1px solid var(--border-muted); color: var(--text-muted); cursor: pointer; text-transform: uppercase; transition: all var(--transition-fast);">Steam Sizing</button>
          <button type="button" class="line-type-tab" data-line-type="slurry" style="flex: 1; padding: var(--space-sm) var(--space-md); font-family: var(--font-mono); font-size: 11px; background: var(--bg-panel); border: 1px solid var(--border-muted); color: var(--text-muted); cursor: pointer; text-transform: uppercase; transition: all var(--transition-fast);">Slurry Sizing</button>
          <button type="button" class="line-type-tab" data-line-type="twophase" style="flex: 1; padding: var(--space-sm) var(--space-md); font-family: var(--font-mono); font-size: 11px; background: var(--bg-panel); border: 1px solid var(--border-muted); color: var(--text-muted); cursor: pointer; text-transform: uppercase; transition: all var(--transition-fast);">Two-Phase Sizing</button>
        </div>

        <!-- LINE SUB-TAB 1: LIQUID SIZING -->
        <div id="line-liquid-content" class="line-type-content active">
          <div class="sizing-grid">
            <!-- Left Column: Inputs -->
            <div class="panel panel-input" style="max-height: calc(100vh - 180px); overflow-y: auto; overflow-x: hidden;">
              <div class="panel-header">
                <span class="panel-title">DESIGN DATA METRICS — LIQUID PIPELINE SIZING</span>
              </div>
              <div class="panel-body">
                <div class="digital-badge">Atmanirbhar Bharat Digitalization</div>
                <form id="line-form">
                  <fieldset class="form-group">
                    <legend>Line Identification Block</legend>
                    <div class="input-grid-3">
                      <div class="input-cell">
                        <label for="line-pid">P&ID No</label>
                        <input type="text" id="line-pid" class="form-control text-data" placeholder="AB-" value="AB-101" required>
                      </div>
                      <div class="input-cell">
                        <label for="line-from">Line From</label>
                        <input type="text" id="line-from" class="form-control text-data" placeholder="Tank" value="Tank" required>
                      </div>
                      <div class="input-cell">
                        <label for="line-to">Line To</label>
                        <input type="text" id="line-to" class="form-control text-data" placeholder="Pump" value="Pump" required>
                      </div>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Fluid Physical Properties</legend>
                    <div class="input-grid-3">
                      <div class="input-cell">
                        <label for="line-fluid">Fluid Name</label>
                        <div class="select-wrapper">
                          <select id="line-fluid" class="form-control">
                            <option value="water" selected>Water</option>
                            <option value="caustic_50">Caustic Soda 50%</option>
                            <option value="dyes">Dyes Typical Solution</option>
                            <option value="wastewater">Wastewater</option>
                            <option value="diesel">Diesel</option>
                            <option value="lpg">LPG Liquid</option>
                            <option value="cooling_water">Cooling Water</option>
                            <option value="sulfur">Sulfur Molten</option>
                            <option value="ammonia">Ammonia Liquid</option>
                            <option value="sulfuric_acid">Sulfuric Acid 98%</option>
                            <option value="phosphoric_acid">Phosphoric Acid 85%</option>
                            <option value="purified_water">Purified Water</option>
                            <option value="ethanol">Ethanol</option>
                            <option value="solvents">Solvents Typical Organic</option>
                            <option value="milk">Milk</option>
                            <option value="boiler_feed">Boiler Feed Water</option>
                            <option value="custom">User Defined</option>
                          </select>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="line-density">Density</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="density" id="line-density" class="form-control text-data" value="997" step="any" required>
                          <span class="unit" data-unit-type="density">kg/m³</span>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="line-viscosity">Viscosity</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="viscosity" id="line-viscosity" class="form-control text-data" value="1.0" step="any" required>
                          <span class="unit" data-unit-type="viscosity">cP</span>
                        </div>
                      </div>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Temperature Data</legend>
                    <div class="input-grid-3">
                      <div class="input-cell">
                        <label for="line-temp-min">Minimum Temp</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="temperature" id="line-temp-min" class="form-control text-data" value="20" step="any" required>
                          <span class="unit" data-unit-type="temperature">°C</span>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="line-temp-norm">Normal Temp</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="temperature" id="line-temp-norm" class="form-control text-data" value="34" step="any" required>
                          <span class="unit" data-unit-type="temperature">°C</span>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="line-temp-max">Maximum Temp</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="temperature" id="line-temp-max" class="form-control text-data" value="50" step="any" required>
                          <span class="unit" data-unit-type="temperature">°C</span>
                        </div>
                      </div>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Pressure Data</legend>
                    <div class="input-row">
                      <div class="input-cell">
                        <label for="line-upstream-press">Upstream Pressure</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="pressure" id="line-upstream-press" class="form-control text-data" value="6" step="any" required>
                          <span class="unit" data-unit-type="pressure">bar G</span>
                        </div>
                      </div>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Pipeline Specifications</legend>
                    <div class="input-grid-3">
                      <div class="input-cell">
                        <label for="line-nps">Nominal Size (NPS)</label>
                        <div class="select-wrapper">
                          <select id="line-nps" class="form-control">
                            <option value="0.5">½"</option>
                            <option value="0.75">¾"</option>
                            <option value="1">1"</option>
                            <option value="1.5">1½"</option>
                            <option value="2">2"</option>
                            <option value="3">3"</option>
                            <option value="4" selected>4"</option>
                            <option value="6">6"</option>
                            <option value="8">8"</option>
                            <option value="10">10"</option>
                            <option value="12">12"</option>
                            <option value="14">14"</option>
                            <option value="16">16"</option>
                            <option value="18">18"</option>
                            <option value="20">20"</option>
                            <option value="24">24"</option>
                          </select>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="line-schedule">Pipe Schedule</label>
                        <div class="select-wrapper">
                          <select id="line-schedule" class="form-control">
                            <option value="STD">STD</option>
                            <option value="20">20</option>
                            <option value="30">30</option>
                            <option value="40" selected>40</option>
                            <option value="60">60</option>
                            <option value="80">80</option>
                            <option value="100">100</option>
                            <option value="120">120</option>
                            <option value="140">140</option>
                            <option value="160">160</option>
                          </select>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="line-material">Pipe Material</label>
                        <div class="select-wrapper">
                          <select id="line-material" class="form-control">
                            <option value="cs" selected>CS (Carbon Steel)</option>
                            <option value="ms">MS (Mild Steel)</option>
                            <option value="gi">GI (Galvanized Iron)</option>
                            <option value="ss304">SS304</option>
                            <option value="ss304l">SS304L</option>
                            <option value="ss316">SS316</option>
                            <option value="ss316l">SS316L</option>
                            <option value="ss321">SS321</option>
                            <option value="ss310">SS310</option>
                            <option value="duplex_ss">Duplex SS</option>
                            <option value="super_duplex_ss">Super Duplex SS</option>
                            <option value="cast_iron">Cast Iron</option>
                            <option value="asphalted_cast_iron">Asphalted Cast Iron</option>
                            <option value="wrought_iron">Wrought Iron</option>
                            <option value="commercial_steel">Commercial Steel</option>
                            <option value="alloy_steel">Alloy Steel</option>
                            <option value="concrete">Concrete</option>
                            <option value="riveted_steel">Riveted Steel</option>
                            <option value="pvc">PVC</option>
                            <option value="cpvc">CPVC</option>
                            <option value="hdpe">HDPE</option>
                            <option value="frp">FRP</option>
                            <option value="ptfe">PTFE Lined</option>
                            <option value="rubber_lined">Rubber Lined</option>
                            <option value="copper">Copper</option>
                            <option value="brass">Brass</option>
                            <option value="hastelloy">Hastelloy C276</option>
                            <option value="monel">Monel 400</option>
                            <option value="inconel">Inconel 600/625</option>
                            <option value="custom">User Defined</option>
                          </select>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="line-roughness">Roughness (ε)</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="length-mm" id="line-roughness" class="form-control text-data" value="0.045" step="any" required>
                          <span class="unit" data-unit-type="length-mm">mm</span>
                        </div>
                      </div>
                      <div class="input-cell" style="grid-column: span 2; display: flex; flex-direction: column; justify-content: center; font-family: var(--font-mono); font-size: 9px; color: var(--text-muted); padding-top: 10px;">
                        <div>OD: <span id="lbl-line-od" style="color: var(--text-header); font-weight: 600;">4.500 in (114.3 mm)</span></div>
                        <div>Thickness: <span id="lbl-line-thickness" style="color: var(--text-header); font-weight: 600;">0.237 in</span></div>
                        <div>Nominal ID: <span id="lbl-line-nominal-id" style="color: var(--text-header); font-weight: 600;">4.026 in (102.3 mm)</span></div>
                        <input type="hidden" id="line-id" value="4.026">
                      </div>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Flow & Velocity Parameters</legend>
                    <div class="input-grid-3">
                      <div class="input-cell">
                        <label for="line-mass-flow">Mass Flowrate</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="mass-flow" id="line-mass-flow" class="form-control text-data" value="99700" step="any" required>
                          <span class="unit" data-unit-type="mass-flow">kg/hr</span>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="line-flow">Design Vol Flow</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="vol-flow" id="line-flow" class="form-control text-data" value="100" step="any" required>
                          <span class="unit" data-unit-type="vol-flow">m³/hr</span>
                        </div>
                      </div>
                      <div class="input-cell" style="display: flex; flex-direction: column; justify-content: center; font-family: var(--font-mono); font-size: 10px; color: var(--text-muted); padding-top: 10px;">
                        <div>Line Velocity:</div>
                        <div style="font-size: 12px; font-weight: 600; color: var(--color-teal);"><span id="lbl-line-velocity">3.38</span> <span class="unit" data-unit-type="velocity">m/s</span></div>
                      </div>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Line Service Configuration</legend>
                    <div class="table-responsive" style="border: 1px solid var(--border-muted); border-radius: var(--radius-sm); overflow: hidden; background: var(--bg-input);">
                      <table class="report-table" style="width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 10px; color: var(--text-main);">
                        <thead>
                          <tr style="border-bottom: 2px solid var(--border-muted); background: rgba(255,255,255,0.02); text-align: left;">
                            <th style="padding: 4px 6px; font-weight: 600; color: var(--text-header); width: 30px; text-align: center; border-right: 1px solid var(--border-muted);">ACT</th>
                            <th style="padding: 4px 6px; font-weight: 600; color: var(--text-header); border-right: 1px solid var(--border-muted);">SERVICE TYPE</th>
                            <th style="padding: 4px 6px; font-weight: 600; color: var(--text-header); border-right: 1px solid var(--border-muted); width: 140px; text-align: center;">VEL RANGE (<span class="unit" data-unit-type="velocity">m/s</span>)</th>
                            <th style="padding: 4px 6px; font-weight: 600; color: var(--text-header); width: 100px; text-align: right;">ΔP LIMIT (<span class="unit" data-unit-type="press-drop-rate">bar/100m</span>)</th>
                          </tr>
                        </thead>
                        <tbody>
                          <tr style="border-bottom: 1px solid var(--border-muted);">
                            <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);">
                              <input type="radio" name="line-active-service" value="suction" style="cursor: pointer; accent-color: var(--color-saffron);">
                            </td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); color: var(--text-header);">Pump Suction</td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); text-align: center; white-space: nowrap;">
                              <input type="number" id="vel-min-suction" class="form-control table-input" value="1.0" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                              to
                              <input type="number" id="vel-max-suction" class="form-control table-input" value="1.5" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                            <td style="padding: 4px; text-align: right;">
                              <input type="number" id="dp-lim-suction" class="form-control table-input" value="0.20" step="any" style="width: 60px; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                          </tr>
                          <tr style="border-bottom: 1px solid var(--border-muted);">
                            <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);">
                              <input type="radio" name="line-active-service" value="discharge" style="cursor: pointer; accent-color: var(--color-saffron);">
                            </td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); color: var(--text-header);">Pump Discharge</td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); text-align: center; white-space: nowrap;">
                              <input type="number" id="vel-min-discharge" class="form-control table-input" value="2.5" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                              to
                              <input type="number" id="vel-max-discharge" class="form-control table-input" value="3.0" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                            <td style="padding: 4px; text-align: right;">
                              <input type="number" id="dp-lim-discharge" class="form-control table-input" value="0.45" step="any" style="width: 60px; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                          </tr>
                          <tr style="border-bottom: 1px solid var(--border-muted);">
                            <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);">
                              <input type="radio" name="line-active-service" value="drain" style="cursor: pointer; accent-color: var(--color-saffron);">
                            </td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); color: var(--text-header);">Drain Pipe</td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); text-align: center; white-space: nowrap;">
                              <input type="number" id="vel-min-drain" class="form-control table-input" value="1.2" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                              to
                              <input type="number" id="vel-max-drain" class="form-control table-input" value="2.1" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                            <td style="padding: 4px; text-align: right;">
                              <input type="number" id="dp-lim-drain" class="form-control table-input" value="0.35" step="any" style="width: 60px; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                          </tr>
                          <tr style="border-bottom: 1px solid var(--border-muted);">
                            <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);">
                              <input type="radio" name="line-active-service" value="general" checked style="cursor: pointer; accent-color: var(--color-saffron);">
                            </td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); color: var(--text-header);">General</td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); text-align: center; white-space: nowrap;">
                              <input type="number" id="vel-min-general" class="form-control table-input" value="2.0" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                              to
                              <input type="number" id="vel-max-general" class="form-control table-input" value="3.0" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                            <td style="padding: 4px; text-align: right;">
                              <input type="number" id="dp-lim-general" class="form-control table-input" value="0.45" step="any" style="width: 60px; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                          </tr>
                          <tr style="border-bottom: 1px solid var(--border-muted);">
                            <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);">
                              <input type="radio" name="line-active-service" value="gravity" style="cursor: pointer; accent-color: var(--color-saffron);">
                            </td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); color: var(--text-header);">Gravity Lines</td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); text-align: center; white-space: nowrap;">
                              <input type="number" id="vel-min-gravity" class="form-control table-input" value="0.5" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                              to
                              <input type="number" id="vel-max-gravity" class="form-control table-input" value="1.0" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                            <td style="padding: 4px; text-align: right;">
                              <input type="number" id="dp-lim-gravity" class="form-control table-input" value="0.10" step="any" style="width: 60px; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                          </tr>
                          <tr style="border-bottom: 1px solid var(--border-muted);">
                            <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);">
                              <input type="radio" name="line-active-service" value="boiler" style="cursor: pointer; accent-color: var(--color-saffron);">
                            </td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); color: var(--text-header);">Boiler Feed Water</td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); text-align: center; white-space: nowrap;">
                              <input type="number" id="vel-min-boiler" class="form-control table-input" value="2.5" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                              to
                              <input type="number" id="vel-max-boiler" class="form-control table-input" value="4.6" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                            <td style="padding: 4px; text-align: right;">
                              <input type="number" id="dp-lim-boiler" class="form-control table-input" value="0.45" step="any" style="width: 60px; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                          </tr>
                          <tr>
                            <td style="padding: 4px; text-align: center; border-right: 1px solid var(--border-muted);">
                              <input type="radio" name="line-active-service" value="user" style="cursor: pointer; accent-color: var(--color-saffron);">
                            </td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); color: var(--text-header);">User Defined</td>
                            <td style="padding: 4px; border-right: 1px solid var(--border-muted); text-align: center; white-space: nowrap;">
                              <input type="number" id="vel-min-user" class="form-control table-input" placeholder="0.0" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                              to
                              <input type="number" id="vel-max-user" class="form-control table-input" placeholder="0.0" step="any" style="width: 40px; display: inline-block; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                            <td style="padding: 4px; text-align: right;">
                              <input type="number" id="dp-lim-user" class="form-control table-input" placeholder="0.0" step="any" style="width: 60px; text-align: right; background: transparent; border: none; color: var(--text-header); padding: 2px;">
                            </td>
                          </tr>
                        </tbody>
                      </table>
                    </div>
                    <div style="margin-top: 6px; font-family: var(--font-mono); font-size: 9px; color: var(--text-muted); text-align: right;">
                      <span id="lbl-active-line-service" class="banner-badge" style="border-color: var(--color-saffron); color: var(--color-saffron); font-size: 9px; padding: 2px 6px;">Active: General | V: 2.00–3.00 m/s | ΔP: 0.45 bar/100m</span>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Pipeline Route & Elevation</legend>
                    <div class="input-grid-3">
                      <div class="input-cell">
                        <label for="line-length">Pipe Length (L)</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="length-m" id="line-length" class="form-control text-data" value="4.0" step="any" required>
                          <span class="unit" data-unit-type="length-m">m</span>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="line-elevation">Elevation Change (h)</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="length-m" id="line-elevation" class="form-control text-data" value="0.5" step="any" required>
                          <span class="unit" data-unit-type="length-m">m</span>
                        </div>
                      </div>
                      <div class="input-cell">
                        <label for="line-other-dp">Other Accessories Drop</label>
                        <div class="input-with-unit">
                          <input type="number" data-unit-type="press-drop" id="line-other-dp" class="form-control text-data" value="0.001" step="any" required>
                          <span class="unit" data-unit-type="press-drop">bar</span>
                        </div>
                      </div>
                    </div>
                  </fieldset>

                  <fieldset class="form-group" style="margin-top: var(--space-md);">
                    <legend>Fittings & Valves — K-Value Method</legend>
                    <div class="table-responsive" style="border: 1px solid var(--border-muted); border-radius: var(--radius-sm); overflow: hidden; background: var(--bg-input); max-height: 250px; overflow-y: auto;">
                      <table class="report-table fittings-table" style="width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 10px; color: var(--text-main);">
                        <thead>
                          <tr style="border-bottom: 2px solid var(--border-muted); background: rgba(255,255,255,0.02); text-align: left; position: sticky; top: 0; z-index: 10;">
                            <th style="padding: 4px 6px; font-weight: 600; color: var(--text-header); border-right: 1px solid var(--border-muted); background: var(--bg-input);">FITTING NAME</th>
