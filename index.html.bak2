              <div class="report-section-title gas-report-section" style="display: none; margin-top: 25px; font-family: var(--font-mono); font-size: 11px; font-weight: 700; color: var(--color-saffron); margin-bottom: 8px;">2. PIPELINE HYDRAULICS PROFILE &mdash; GAS</div>
              <table class="report-table gas-report-table" style="display: none; width: 100%; border-collapse: collapse; margin-bottom: 20px; font-family: var(--font-mono); font-size: 10px; color: var(--text-main);">
